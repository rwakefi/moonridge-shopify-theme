<script>
  document.addEventListener('DOMContentLoaded', function() {
    const videoToggle = document.getElementById('EventsVideoToggle');
    if (!videoToggle) return;

    const videos = document.querySelectorAll('.events-video-banner__bg video');
    const pauseIcon = videoToggle.querySelector('.icon-pause');
    const playIcon = videoToggle.querySelector('.icon-play');

    videoToggle.addEventListener('click', function() {
      // Check first visible video's state
      let isCurrentlyPaused = false;
      videos.forEach(v => {
        if (getComputedStyle(v).display !== 'none') {
          isCurrentlyPaused = v.paused;
        }
      });
      
      videos.forEach(video => {
        if (isCurrentlyPaused) {
          video.play();
        } else {
          video.pause();
        }
      });

      // Update UI
      if (isCurrentlyPaused) {
        pauseIcon.style.display = 'block';
        playIcon.style.display = 'none';
        videoToggle.setAttribute('aria-label', 'Pause Video');
      } else {
        pauseIcon.style.display = 'none';
        playIcon.style.display = 'block';
        videoToggle.setAttribute('aria-label', 'Play Video');
      }
    });
  });
</script>
