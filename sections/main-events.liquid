{% style %}
  /* Hide breadcrumbs on events page (mobile + desktop) */
  .breadcrumbs {
    display: none !important;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Three-way video swap: mobile / laptop / desktop */
  video.events-video--mobile  { display: none !important; }
  video.events-video--laptop  { display: none !important; }
  /* Laptop (990px–1399px) */
  @media screen and (min-width: 990px) and (max-width: 1399px) {
    video.events-video--desktop { display: none !important; }
    video.events-video--laptop  { display: block !important; }
  }
  /* Mobile (up to 989px) */
  @media screen and (max-width: 989px) {
    video.events-video--desktop { display: none !important; }
    video.events-video--mobile  { display: block !important; }
  }
  .events-video-banner {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }

  @media screen and (min-width: 990px) {
    .events-video-banner {
      min-height: 600px;
      aspect-ratio: 16 / 9;
      max-height: 80vh;
    }
  }
  .events-video-banner__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .events-video-banner__bg video {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: var(--video-alignment, center center);
    display: block;
  }
  
  @media screen and (max-width: 768px) {
    .events-video-banner__title {
      font-size: 36px;
    }
    .event-category-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .event-category-header__image-container {
      width: 100%;
      margin: 0 0 20px 0;
    }
    .events-form-wrapper {
      padding: 24px 20px;
    }
    .events-form-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

{% if section.settings.hero_video != blank %}
  <div class="events-video-banner" style="--video-alignment: {{ section.settings.video_alignment }};">
    <div class="events-video-banner__bg">
      {%- liquid
        assign poster = section.settings.poster_image | image_url: width: 1600
        assign laptop_video = section.settings.laptop_video | default: section.settings.hero_video
        assign mobile_video = section.settings.mobile_video | default: laptop_video
      -%}

      {{- '<!-- Desktop video (1400px+) -->' }}
      <video class="events-video--desktop" autoplay loop muted playsinline poster="{{ poster }}">
        {% for source in section.settings.hero_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>

      {{- '<!-- Laptop video (990px–1399px): uses laptop_video if set, else falls back to desktop video -->' }}
      <video class="events-video--laptop" autoplay loop muted playsinline poster="{{ poster }}">
        {% for source in laptop_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>

      {{- '<!-- Mobile video (up to 989px): uses mobile_video if set, else laptop, else desktop -->' }}
      <video class="events-video--mobile" autoplay loop muted playsinline poster="{{ poster }}">
        {% for source in mobile_video.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    </div>
    <div class="events-video-banner__overlay"></div>
    <div class="events-video-banner__content">
      {% if section.settings.banner_title != blank %}
        <h1 class="events-video-banner__title">{{ section.settings.banner_title | newline_to_br }}</h1>
      {% endif %}
      {% if section.settings.banner_text != blank %}
        <div class="events-video-banner__text">{{ section.settings.banner_text }}</div>
      {% endif %}
      <div class="events-video-banner__buttons">
        <a href="#event-inquiry-form" class="banner-button banner-button--secondary">Event Form</a>
      </div>
    </div>
  </div>
{% endif %}

<div class="events-directory">
  <div class="events-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category_header' %}
        <div class="event-category-header" id="{{ block.settings.anchor_id | handleize }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="event-category-header__image-container">
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" class="event-category-header__image">
            </div>
          {% endif %}
          <div class="event-category-header__text">
            <h2>{{ block.settings.title }}</h2>
            {% if block.settings.description != blank %}
              <div class="event-category-header__desc">{{ block.settings.description }}</div>
            {% endif %}
          </div>
        </div>
      {% elsif block.type == 'event' %}
        <div class="event-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="event-card__image">
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'event-card__image' }}
          {% endif %}
          
          <div class="event-card__content">
            {% if block.settings.date != blank %}
              <div class="event-card__date">{{ block.settings.date }}</div>
            {% endif %}
            
            <h3 class="event-card__title">{{ block.settings.title }}</h3>
            
            {% if block.settings.description != blank %}
              <div class="event-card__desc">{{ block.settings.description }}</div>
            {% endif %}
            
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="event-card__button">{{ block.settings.button_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
    
    {% if section.blocks.size == 0 %}
      <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #777;">
        <p>No events currently scheduled. Add some blocks in the theme editor!</p>
      </div>
    {% endif %}

    <div class="events-form-wrapper" id="event-inquiry-form">
      <h2 style="text-align: center; margin-bottom: 24px; font-family: var(--font-heading-family); font-size: 28px;">Inquire about Booking us for your next event</h2>
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="form-status form-status-list form__message" tabindex="-1" autofocus style="color: green; text-align: center; margin-bottom: 16px;">
            Thanks for reaching out! We will get back to you soon.
          </div>
        {% elsif form.errors %}
          <div class="form__message" style="color: red; text-align: center; margin-bottom: 16px;">
            <div class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
              Please check your info and try again.
            </div>
          </div>
        {% endif %}
        <div class="events-form-grid">
          <div class="field">
            <input class="field__input" autocomplete="name" type="text" id="ContactForm-first_name" name="contact[First Name]" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}" placeholder="First name" required>
            <label class="field__label" for="ContactForm-first_name">First name</label>
          </div>
          <div class="field">
            <input class="field__input" type="text" id="ContactForm-last_name" name="contact[Last Name]" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}" placeholder="Last name" required>
            <label class="field__label" for="ContactForm-last_name">Last name</label>
          </div>
          <div class="field">
            <input type="tel" id="ContactForm-phone" class="field__input" autocomplete="tel" name="contact[Phone]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" placeholder="Phone number" required>
            <label class="field__label" for="ContactForm-phone">Phone</label>
          </div>
          <div class="field">
            <input autocomplete="email" type="email" id="ContactForm-email" class="field__input" name="contact[email]" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" aria-required="true" placeholder="Email" required>
            <label class="field__label" for="ContactForm-email">Email</label>
          </div>
          <div class="field">
            <input type="text" id="ContactForm-event_type" class="field__input" name="contact[Event Name / Type of Event]" placeholder="Event Name/Type of Event" required>
            <label class="field__label" for="ContactForm-event_type">Event Name/Type of Event</label>
          </div>
          <div class="field">
            <input type="number" id="ContactForm-headcount" class="field__input" name="contact[Expected Headcount]" placeholder="Expected # of people" required>
            <label class="field__label" for="ContactForm-headcount">Expected # of people</label>
          </div>
          <div class="field field--full-width">
            <input type="text" id="ContactForm-location" class="field__input" name="contact[Location of Event]" placeholder="Location of The Event" required>
            <label class="field__label" for="ContactForm-location">Location of The Event</label>
          </div>
        </div>
        <div class="contact__button" style="text-align: center; margin-top: 24px;">
          <button type="submit" class="button button--primary" style="min-width: 200px;">
            Submit Request
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Events Directory",
  "settings": [
    {
      "type": "video",
      "id": "hero_video",
      "label": "Desktop Video (1400px+)",
      "info": "Ideal size: 1920×1080px (16:9 landscape). Used on large desktop monitors. Required — all other slots fall back to this if left empty."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Video Poster Image",
      "info": "Displays while the video is loading. Highly recommended for speed."
    },
    {
      "type": "video",
      "id": "laptop_video",
      "label": "Laptop Video (990px–1399px) (Optional)",
      "info": "Ideal size: 1440×810px (16:9 landscape). Optimized for laptop screens. If left empty, the Desktop video will be used."
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile Video (under 990px) (Optional)",
      "info": "Ideal size: 1080×1920px (9:16 vertical/portrait). Optimized for phones and tablets. If left empty, the Laptop video (or Desktop if none) will be used."
    },
    {
      "type": "select",
      "id": "video_alignment",
      "label": "Video Focal Point",
      "info": "If the video is cropping, adjust this to focus on the top or bottom.",
      "options": [
        {
          "value": "center top",
          "label": "Top (e.g., show heads)"
        },
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center bottom",
          "label": "Bottom"
        }
      ],
      "default": "center center"
    },
    {
      "type": "textarea",
      "id": "banner_title",
      "label": "Video Overlay Title",
      "info": "Press Enter in this box to create a line break in the heading.",
      "default": "Make Your Event Special"
    },
    {
      "type": "richtext",
      "id": "banner_text",
      "label": "Video Overlay Text",
      "default": "<p>Discover the Moon Ridge experience.</p>"
    }
  ],
  "blocks": [
    {
      "type": "category_header",
      "name": "Category Heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Weddings"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Framed Category Image"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Category Description (Optional)"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor ID",
          "info": "Used for dropdown links. Example: 'weddings'. The link will be /pages/events#weddings",
          "default": "weddings"
        }
      ]
    },
    {
      "type": "event",
      "name": "Event",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Event Image"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date & Time",
          "default": "Oct 15, 2026 | 6:00 PM"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event Title",
          "default": "Hat Shaping Workshop"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Learn the art of custom hat shaping with our expert team.</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "RSVP Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Event Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Events Directory",
      "blocks": [
        {
          "type": "category_header",
          "settings": {
            "title": "Weddings",
            "anchor_id": "weddings"
          }
        },
        {
          "type": "event"
        },
        {
          "type": "category_header",
          "settings": {
            "title": "In Store",
            "anchor_id": "in-store"
          }
        },
        {
          "type": "event"
        }
      ]
    }
  ]
}
{% endschema %}
