{% style %}
  /* Hide breadcrumbs on events page (mobile + desktop) */
  .breadcrumbs {
    display: none !important;
  }

  html {
    scroll-behavior: smooth;
  }

  /* Three-way video swap: mobile / laptop / desktop */
  video.events-video--mobile  { display: none !important; }
  video.events-video--laptop  { display: none !important; }
  /* Laptop (990px–1399px) */
  @media screen and (min-width: 990px) and (max-width: 1399px) {
    video.events-video--desktop { display: none !important; }
    video.events-video--laptop  { display: block !important; }
  }
  /* Mobile (up to 989px) */
  @media screen and (max-width: 989px) {
    video.events-video--desktop { display: none !important; }
    video.events-video--mobile  { display: block !important; }
  }
  .events-video-banner {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }

  @media screen and (min-width: 990px) {
    .events-video-banner {
      min-height: 600px;
      aspect-ratio: 16 / 9;
      max-height: 80vh;
    }
  }
  .events-video-banner__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .events-video-banner__bg video {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: var(--video-alignment, center center);
    display: block;
  }
  .events-video-banner__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 2;
  }
  .events-video-banner__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #ffffff;
    max-width: 800px;
    padding: 0 20px;
  }
  .events-video-banner__title {
    font-family: var(--font-heading-family);
    font-size: 56px;
    font-weight: 700;
    margin: 0 0 16px 0;
    color: #fff;
    line-height: 1.05;
    letter-spacing: 0.01em;
  }
  .events-video-banner__text {
    font-size: 18px;
    margin: 0 0 32px 0;
    color: #fff;
    line-height: 1.5;
  }
  .events-video-banner__buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .banner-button {
    display: inline-block;
    padding: 14px 32px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .banner-button--primary { background: #ffffff; color: #111111; }
  .banner-button--primary:hover { background: #e6e6e6; }
  .banner-button--secondary { background: transparent; color: #ffffff; border: 1px solid #ffffff; }
  .banner-button--secondary:hover { background: rgba(255,255,255,0.1); }

  .events-video-control {
    position: absolute;
    bottom: 30px;
    right: 30px;
    z-index: 10;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.6;
    padding: 0;
  }
  .events-video-control:hover {
    opacity: 1;
    background: rgba(0, 0, 0, 0.6);
    transform: scale(1.05);
  }
  .events-video-control svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }
  @media screen and (max-width: 749px) {
    .events-video-control {
      bottom: 20px;
      right: 20px;
      width: 38px;
      height: 38px;
    }
  }

  /* Events directory body */
  .events-directory {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
    font-family: var(--font-body-family);
  }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
  }
  .event-category-header {
    grid-column: 1 / -1;
    margin-top: 80px;
    padding-bottom: 40px;
    border-bottom: 1px solid #eee;
    display: flex;
    align-items: center;
    gap: 60px;
  }
  .event-category-header__media-group {
    position: relative;
    flex-shrink: 0;
    width: 280px;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .event-category-header__frame {
    position: relative;
    background: #fff;
    padding: 8px;
    border-radius: 4px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    overflow: hidden;
    z-index: 2;
    width: 100%;
    height: 100%;
    border: 1px solid #eee;
  }
  .event-category-header__frame video,
  .event-category-header__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .event-category-header__frame--secondary {
    position: absolute;
    width: 160px;
    height: 160px;
    z-index: 1;
    top: -20px;
    right: -40px;
    transform: rotate(6deg);
  }
  .event-category-header__frame--tertiary {
    position: absolute;
    width: 140px;
    height: 140px;
    z-index: 3;
    bottom: -20px;
    left: -40px;
    transform: rotate(-8deg);
  }
  .event-category-header__text { flex-grow: 1; }
  .event-category-header h2 {
    font-family: var(--font-heading-family);
    font-size: 36px;
    font-weight: 600;
    color: #111;
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .event-category-header__desc { font-size: 16px; color: #555; max-width: 700px; line-height: 1.6; }
  .event-card { border: 1px solid #eaeaea; border-radius: 8px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }
  .event-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.06); }
  .event-card__image { width: 100%; height: 200px; object-fit: cover; background: #f5f5f5; }
  .event-card__content { padding: 24px; }
  .event-card__date { display: inline-block; font-size: 13px; font-weight: 600; text-transform: uppercase; color: #C5A059; margin-bottom: 8px; letter-spacing: 0.5px; }
  .event-card__title { font-family: var(--font-heading-family); font-size: 22px; font-weight: 600; margin: 0 0 12px 0; color: #111; }
  .event-card__desc { font-size: 15px; color: #555; line-height: 1.5; margin: 0 0 20px 0; }
  .event-card__button { display: inline-block; padding: 10px 20px; background: #111; color: #fff; text-decoration: none; border-radius: 4px; font-size: 14px; font-weight: 500; transition: background 0.2s; }
  .event-card__button:hover { background: #333; }
  .events-form-wrapper {
    grid-column: 1 / -1;
    max-width: 800px;
    margin: 40px auto 0;
    width: 100%;
    padding: 40px;
    background: #fafafa;
    border-radius: 8px;
    border: 1px solid #eaeaea;
  }
  .events-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .events-form-grid .field--full-width { grid-column: 1 / -1; }

  @media screen and (max-width: 768px) {
    .events-video-banner__title { font-size: 36px; }
    .event-category-header {
      flex-direction: column;
      gap: 40px;
      text-align: center;
      padding-bottom: 40px;
    }
    .event-category-header__media-group {
      width: 240px;
      height: 240px;
    }
    .event-category-header__frame--secondary {
      width: 130px;
      height: 130px;
      right: -30px;
    }
    .event-category-header__frame--tertiary {
      width: 110px;
      height: 110px;
      left: -30px;
    }.event-category-header__image-container { width: 100%; margin: 0 0 20px 0; }
    .events-form-wrapper { padding: 24px 20px; }
    .events-form-grid { grid-template-columns: 1fr; }
  }
{% endstyle %}


{% if section.settings.hero_video != blank %}
  <div class="events-video-banner" style="--video-alignment: {{ section.settings.video_alignment }};">
    <div class="events-video-banner__bg">
      {%- liquid
        assign poster = section.settings.poster_image | image_url: width: 1600
        assign laptop_video = section.settings.laptop_video | default: section.settings.hero_video
        assign mobile_video = section.settings.mobile_video | default: laptop_video
      -%}

      <!-- Desktop video (1400px+) -->
      <video class="events-video--desktop" autoplay loop muted playsinline{% if poster != blank %} poster="{{ poster }}"{% endif %}>
        {%- for source in section.settings.hero_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>

      <!-- Laptop video (990px-1399px): falls back to desktop if not set -->
      <video class="events-video--laptop" autoplay loop muted playsinline{% if poster != blank %} poster="{{ poster }}"{% endif %}>
        {%- for source in laptop_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>

      <!-- Mobile video (under 990px): falls back to laptop then desktop if not set -->
      <video class="events-video--mobile" autoplay loop muted playsinline{% if poster != blank %} poster="{{ poster }}"{% endif %}>
        {%- for source in mobile_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
    </div>
    <div class="events-video-banner__overlay"></div>
    <div class="events-video-banner__content">
      {% if section.settings.banner_title != blank %}
        <h1 class="events-video-banner__title">{{ section.settings.banner_title | newline_to_br }}</h1>
      {% endif %}
      {% if section.settings.banner_text != blank %}
        <div class="events-video-banner__text">{{ section.settings.banner_text }}</div>
      {% endif %}
      <div class="events-video-banner__buttons">
        <a href="#event-inquiry-form" class="banner-button banner-button--secondary">Event Form</a>
      </div>
    </div>
    <button type="button" class="events-video-control" id="EventsVideoToggle" aria-label="Pause Video">
      <span class="icon-pause">
        <svg viewBox="0 0 448 512"><path d="M144 479H48c-26.5 0-48-21.5-48-48V79c0-26.5 21.5-48 48-48h96c26.5 0 48 21.5 48 48v352c0 26.5-21.5 48-48 48zm304-48V79c0-26.5-21.5-48-48-48h-96c-26.5 0-48 21.5-48 48v352c0 26.5 21.5 48 48 48h96c26.5 0 48-21.5 48-48z"/></svg>
      </span>
      <span class="icon-play" style="display: none;">
        <svg viewBox="0 0 448 512"><path d="M424.4 214.7L72.4 6.6C43.8-10.3 0 6.1 0 47.9V464c0 37.5 40.7 60.1 72.4 41.3l352-208c31.4-18.5 31.5-64.1 0-82.6z"/></svg>
      </span>
    </button>
  </div>
{% endif %}

<div class="events-directory">
  <div class="events-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category_header' %}
        <div class="event-category-header" id="{{ block.settings.anchor_id | handleize }}" {{ block.shopify_attributes }}>
          
          <div class="event-category-header__media-group">
            {% comment %} Primary Frame {% endcomment %}
            <div class="event-category-header__frame">
              {% if block.settings.video != blank %}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
              {% elsif block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}">
              {% else %}
                {{ 'image' | placeholder_svg_tag }}
              {% endif %}
            </div>

            {% comment %} Secondary Frame {% endcomment %}
            {% if block.settings.image_2 != blank %}
              <div class="event-category-header__frame event-category-header__frame--secondary">
                <img src="{{ block.settings.image_2 | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}">
              </div>
            {% endif %}

            {% comment %} Tertiary Frame {% endcomment %}
            {% if block.settings.image_3 != blank %}
              <div class="event-category-header__frame event-category-header__frame--tertiary">
                <img src="{{ block.settings.image_3 | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}">
              </div>
            {% endif %}
          </div>

          <div class="event-category-header__text">
            <h2>{{ block.settings.title }}</h2>
            {% if block.settings.description != blank %}
              <div class="event-category-header__desc">{{ block.settings.description }}</div>
            {% endif %}
          </div>
        </div>
      {% elsif block.type == 'event' %}
        <div class="event-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="event-card__image">
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'event-card__image' }}
          {% endif %}
          
          <div class="event-card__content">
            {% if block.settings.date != blank %}
              <div class="event-card__date">{{ block.settings.date }}</div>
            {% endif %}
            
            <h3 class="event-card__title">{{ block.settings.title }}</h3>
            
            {% if block.settings.description != blank %}
              <div class="event-card__desc">{{ block.settings.description }}</div>
            {% endif %}
            
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="event-card__button">{{ block.settings.button_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
    
    {% if section.blocks.size == 0 %}
      <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #777;">
        <p>No events currently scheduled. Add some blocks in the theme editor!</p>
      </div>
    {% endif %}

    <div class="events-form-wrapper" id="event-inquiry-form">
      <h2 style="text-align: center; margin-bottom: 24px; font-family: var(--font-heading-family); font-size: 28px;">Inquire about Booking us for your next event</h2>
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="form-status form-status-list form__message" tabindex="-1" autofocus style="color: green; text-align: center; margin-bottom: 16px;">
            Thanks for reaching out! We will get back to you soon.
          </div>
        {% elsif form.errors %}
          <div class="form__message" style="color: red; text-align: center; margin-bottom: 16px;">
            <div class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
              Please check your info and try again.
            </div>
          </div>
        {% endif %}
        <div class="events-form-grid">
          <div class="field">
            <input class="field__input" autocomplete="name" type="text" id="ContactForm-first_name" name="contact[First Name]" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}" placeholder="First name" required>
            <label class="field__label" for="ContactForm-first_name">First name</label>
          </div>
          <div class="field">
            <input class="field__input" type="text" id="ContactForm-last_name" name="contact[Last Name]" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}" placeholder="Last name" required>
            <label class="field__label" for="ContactForm-last_name">Last name</label>
          </div>
          <div class="field">
            <input type="tel" id="ContactForm-phone" class="field__input" autocomplete="tel" name="contact[Phone]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" placeholder="Phone number" required>
            <label class="field__label" for="ContactForm-phone">Phone</label>
          </div>
          <div class="field">
            <input autocomplete="email" type="email" id="ContactForm-email" class="field__input" name="contact[email]" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" aria-required="true" placeholder="Email" required>
            <label class="field__label" for="ContactForm-email">Email</label>
          </div>
          <div class="field">
            <input type="text" id="ContactForm-event_type" class="field__input" name="contact[Event Name / Type of Event]" placeholder="Event Name/Type of Event" required>
            <label class="field__label" for="ContactForm-event_type">Event Name/Type of Event</label>
          </div>
          <div class="field">
            <input type="number" id="ContactForm-headcount" class="field__input" name="contact[Expected Headcount]" placeholder="Expected # of people" required>
            <label class="field__label" for="ContactForm-headcount">Expected # of people</label>
          </div>
          <div class="field field--full-width">
            <input type="text" id="ContactForm-location" class="field__input" name="contact[Location of Event]" placeholder="Location of The Event" required>
            <label class="field__label" for="ContactForm-location">Location of The Event</label>
          </div>
        </div>
        <div class="contact__button" style="text-align: center; margin-top: 24px;">
          <button type="submit" class="button button--primary" style="min-width: 200px;">
            Submit Request
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</div>

