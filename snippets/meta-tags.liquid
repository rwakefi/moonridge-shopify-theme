{%- liquid
  assign primary_keyword = "Hat Shaping"
  if request.page_type == 'product'
    assign primary_keyword = product.title
  elsif request.page_type == 'collection'
    assign primary_keyword = collection.title
  elsif request.page_type == 'article'
    assign primary_keyword = article.title
  endif

  assign secondary_keyword = "Expert Hat Restoration"
  if request.page_type == 'index'
    assign secondary_keyword = "Fayetteville, AR"
  endif

  assign seo_title = primary_keyword | append: " - " | append: shop.name | append: " | " | append: secondary_keyword
  assign seo_description = page_description | default: shop.description | default: shop.name | strip_html | strip | truncate: 160
  
  assign og_title = seo_title
  assign og_description = seo_description
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  
  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  endif
%}

<meta name="geo.region" content="US-AR" />
<meta name="geo.placename" content="Fayetteville" />
<meta name="geo.position" content="36.0921;-94.1531" />
<meta name="ICBM" content="36.0921, -94.1531" />

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url: width: 1200, height: 630, crop: 'center' }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200, height: 630, crop: 'center' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200, height: 630, crop: 'center' }}">
{%- endif -%}

