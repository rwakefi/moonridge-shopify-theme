{{ 'section-hat-finder-cta.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign button_link = section.settings.button_link
  if button_link == blank
    assign button_link = '/pages/hat-finder'
  endif
-%}

<section class="hat-finder-cta section-{{ section.id }}-padding" id="HatFinderCta-{{ section.id }}">
  <div class="page-width hat-finder-cta__inner">
    <div class="hat-finder-cta__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hat-finder-cta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hat-finder-cta__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="hat-finder-cta__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="hat-finder-cta__actions">
      <a href="{{ button_link }}" class="hat-finder-cta__button hat-finder-cta__button--primary">
        {{ section.settings.button_label | escape }}
      </a>
      {%- if section.settings.show_secondary_link and section.settings.secondary_label != blank -%}
        <a
          href="{{ section.settings.secondary_link | default: 'https://hatfinder.moonridgecompany.com' }}"
          class="hat-finder-cta__button hat-finder-cta__button--secondary"
          {% if section.settings.secondary_new_tab %}target="_blank" rel="noopener"{% endif %}
        >
          {{ section.settings.secondary_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hat Finder CTA",
  "tag": "section",
  "class": "section-hat-finder-cta",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Moon Ridge Hat Finder"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find your perfect hat in minutes"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Match crown, brim, and material to your style — then shop hats that fit."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Launch Hat Finder"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Use /pages/hat-finder once the page is created in Admin."
    },
    {
      "type": "checkbox",
      "id": "show_secondary_link",
      "label": "Show secondary link",
      "default": false
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary link label",
      "default": "Open in full screen"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link URL"
    },
    {
      "type": "checkbox",
      "id": "secondary_new_tab",
      "label": "Open secondary link in new tab",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#2d2926"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#312110"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Hat Finder CTA"
    }
  ]
}
{% endschema %}

<style>
  #HatFinderCta-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    --hat-finder-cta-btn-bg: {{ section.settings.button_background }};
    --hat-finder-cta-btn-text: {{ section.settings.button_text }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  
  #HatFinderCta-{{ section.id }} .hat-finder-cta__inner {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  #HatFinderCta-{{ section.id }} .hat-finder-cta__copy {
    flex: 1 1 auto;
    min-width: 0;
  }
  
  #HatFinderCta-{{ section.id }} .hat-finder-cta__eyebrow {
    margin: 0 0 0.15rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  
  #HatFinderCta-{{ section.id }} .hat-finder-cta__heading {
    margin: 0;
    font-size: 15px;
    line-height: 1.2;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  
  #HatFinderCta-{{ section.id }} .hat-finder-cta__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 0 0 auto;
  }
  
  #HatFinderCta-{{ section.id }} .hat-finder-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color 0.2s, color 0.2s;
  }

  @media screen and (max-width: 749px) {
    #HatFinderCta-{{ section.id }} .hat-finder-cta__inner {
      flex-wrap: wrap;
      flex-direction: row;
      justify-content: center;
      align-items: center;
      text-align: center;
      gap: 0.5rem 0.75rem;
    }
    
    #HatFinderCta-{{ section.id }} .hat-finder-cta__copy {
      flex: 0 1 auto;
    }
    
    #HatFinderCta-{{ section.id }} .hat-finder-cta__eyebrow {
      display: none !important;
    }
    
    #HatFinderCta-{{ section.id }} .hat-finder-cta__heading {
      margin: 0;
      font-size: 15px;
      display: inline;
    }
    
    #HatFinderCta-{{ section.id }} .hat-finder-cta__actions {
      display: inline-flex;
      justify-content: center;
      flex: 0 0 auto;
    }
    
    #HatFinderCta-{{ section.id }} .hat-finder-cta__button {
      width: auto;
      min-height: auto;
      padding: 0;
      background: transparent !important;
      border: none !important;
      font-size: 15px;
      text-transform: uppercase;
      text-decoration: underline;
      color: {{ section.settings.text_color }} !important;
      font-weight: 700;
    }
    
    #HatFinderCta-{{ section.id }} .hat-finder-cta__button:hover {
      opacity: 0.8;
    }
  }
</style>
