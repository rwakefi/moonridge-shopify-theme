<style>
  @import url('https://fonts.googleapis.com/css2?family=Tenor+Sans&display=swap');

  .rm-brand-switcher {
    background-color: #f7f7f7;
    border-bottom: 1px solid #e0e0e0;
    display: flex;
    justify-content: flex-start;
    align-items: stretch;
    padding: 0;
    padding-left: 15rem;
    margin: 0;
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .rm-brand-tabs {
    display: flex;
    align-items: stretch;
    position: relative;
  }

  .rm-brand-tab {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 12px 30px;
    color: #999;
    text-decoration: none;
    border-right: 1px solid #e0e0e0;
    border-top: 3px solid transparent;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    line-height: 1.4;
    width: auto;
    min-width: 190px;
  }

  .rm-brand-tab.is-active {
    background-color: #ffffff;
    color: #312110;
    border-top: 3px solid #C5A059;
    border-bottom: 1px solid #ffffff;
    margin-bottom: -1px;
    font-weight: 600;
    z-index: 2;
  }

  .rm-brand-tab:hover:not(.is-active) {
    color: #312110;
    background-color: #f0f0f0;
    border-top: 3px solid rgba(197, 160, 89, 0.4);
  }

  .rm-brand-tab-logo {
    height: 38px;
    width: auto;
    display: block;
  }

  .rm-brand-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: auto;
    margin-right: 24px;
    align-self: center;
    flex-shrink: 0;
  }

  .rm-brand-commerce-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rm-brand-commerce-link {
    font-family: var(--font-heading-family);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: #312110;
    opacity: 0.72;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .rm-brand-commerce-link:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .rm-brand-commerce-sep {
    color: #c4b49a;
    opacity: 0.7;
    font-size: 12px;
    line-height: 1;
    user-select: none;
  }

  .rm-brand-promo-btn {
    font-family: var(--font-heading-family);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: #312110;
    background-color: transparent;
    border: 1px solid #c5a059;
    padding: 8px 20px;
    margin-left: 0;
    transition: all 0.3s ease;
    border-radius: 2px;
    align-self: center;
  }

  .rm-brand-promo-btn:hover {
    background-color: #C5A059;
    border-color: #C5A059;
    color: #ffffff;
  }

  /* Hide mobile-only elements on desktop */
  .rm-brand-switcher-search,
  .rm-mobile-search-overlay,
  .rm-mobile-search-panel {
    display: none !important;
  }

  @media screen and (max-width: 989px) {
    .rm-brand-switcher {
      padding-left: clamp(1rem, 3vw, 2rem) !important;
    }

    .rm-brand-actions {
      gap: 10px;
      margin-right: clamp(0.75rem, 2vw, 1.25rem);
    }

    .rm-brand-commerce-link {
      font-size: 11px;
      letter-spacing: 0.08em;
    }

    .rm-brand-promo-btn {
      font-size: 11px;
      padding: 7px 14px;
      letter-spacing: 0.08em;
    }

    .rm-brand-tab {
      min-width: clamp(120px, 16vw, 170px);
      padding: 10px 18px;
      font-size: 11px;
    }

    .rm-brand-tab-logo {
      height: 32px !important;
    }
  }

  @media screen and (max-width: 749px) {
    .section-brand-switcher {
      width: 100%;
      max-width: 100%;
      overflow-x: clip;
    }

    .rm-brand-switcher { 
      padding-left: 0 !important;
      display: flex !important;
      align-items: stretch !important;
      height: 60px;
      width: 100%;
      max-width: 100%;
    }
    .rm-brand-tabs { 
      flex: 1;
      display: flex !important; 
      align-items: stretch;
    }
    .rm-brand-tab { 
      flex: 1;
      width: auto !important;
      min-width: 0 !important;
      display: flex;
      align-items: center;
      justify-content: center; 
      font-size: 12px; 
      border-right: 1px solid #e0e0e0;
      border-top: none;
      padding: 8px 10px !important;
      line-height: 1.4;
    }
    .rm-brand-tab-logo {
      height: 26px !important;
    }
    .rm-brand-tab.is-active {
      /* Keep top border as fallback */
    }
    .rm-brand-tab:last-child {
      border-right: none;
    }
    .rm-brand-actions {
      display: none !important;
    }
    .rm-brand-hamburger {
      display: flex !important;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 50px;
      background: none;
      border: none;
      border-right: 1px solid #e0e0e0;
      cursor: pointer;
      padding: 0;
    }
    .rm-brand-hamburger svg {
      width: 22px !important;
      height: 22px !important;
    }
    .rm-brand-switcher-cart {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      align-self: stretch;
      flex-shrink: 0;
      width: 50px;
      height: auto !important;
      box-shadow: -1px 0 0 #e0e0e0;
      padding: 0 !important;
      color: #312110 !important;
    }
    .rm-brand-switcher-cart svg {
      width: 22px !important;
      height: 22px !important;
    }
    .rm-brand-switcher-cart .cart-count-bubble {
      position: absolute;
      top: 10px;
      right: 10px;
    }
    /* Hide desktop cart on mobile */
    .header__icon--cart:not(.rm-brand-switcher-cart) {
      display: none !important;
    }
    /* Mobile search icon */
    .rm-brand-switcher-search {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      align-self: stretch;
      flex-shrink: 0;
      width: 46px;
      height: auto !important;
      box-shadow: -1px 0 0 #e0e0e0;
      padding: 0 !important;
      color: #312110 !important;
      background: none;
      border: none;
      cursor: pointer;
    }
    .rm-brand-switcher-search svg {
      width: 20px !important;
      height: 20px !important;
    }
    /* Mobile search overlay */
    .rm-mobile-search-overlay {
      display: none !important;
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,0.5);
      z-index: 9998;
    }
    .rm-mobile-search-overlay.is-open {
      display: block !important;
    }
    .rm-mobile-search-panel {
      display: block !important;
      position: fixed;
      top: 0; left: 0; right: 0;
      background: #fff;
      z-index: 9999;
      padding: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
      transform: translateY(-100%);
      transition: transform 0.3s ease;
    }
    .rm-mobile-search-panel.is-open {
      transform: translateY(0);
    }
    .rm-mobile-search-form {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .rm-mobile-search-input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 16px;
      font-family: var(--font-body-family);
      outline: none;
      -webkit-appearance: none;
    }
    .rm-mobile-search-input:focus {
      border-color: #312110;
    }
    .rm-mobile-search-close {
      background: none;
      border: none;
      padding: 8px;
      cursor: pointer;
      color: #312110;
    }
    .rm-mobile-search-close svg {
      width: 20px;
      height: 20px;
    }
  }
</style>

<div class="rm-brand-switcher">
  <button class="rm-brand-hamburger" onclick="document.querySelector('.header__icon--menu').click();" style="display: none;" aria-label="Menu">
    <svg class="icon icon-hamburger" aria-hidden="true" focusable="false" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1H17" stroke="#312110" stroke-width="2" stroke-linecap="round"/>
      <path d="M1 8H17" stroke="#312110" stroke-width="2" stroke-linecap="round"/>
      <path d="M1 15H17" stroke="#312110" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <div class="rm-brand-tabs" id="rm-brand-tabs">
    {% assign active_index = 0 %}
    {% for block in section.blocks %}
      {% assign tab_link = block.settings.link %}
      {% if tab_link == request.path %}
        {% assign active_index = forloop.index0 %}
      {% elsif tab_link != '/' and request.path contains tab_link %}
        {% assign active_index = forloop.index0 %}
      {% endif %}
    {% endfor %}
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}"
         class="rm-brand-tab {% if forloop.index0 == active_index %}is-active{% endif %}"
         data-tab-index="{{ forloop.index0 }}"
         {{ block.shopify_attributes }}>
        {% if block.settings.title == 'Moon Ridge' %}
          <img src="{{ 'logo-horizontal.png' | asset_url }}" alt="Moon Ridge" class="rm-brand-tab-logo">
        {% else %}
          {{ block.settings.title }}
        {% endif %}
      </a>
    {% endfor %}
  </div>

  <div class="rm-brand-actions">
    <div class="rm-brand-commerce-links">
      <a
        href="{{ section.settings.shop_link | default: '/pages/shop-hats' }}"
        class="rm-brand-commerce-link"
      >
        {{ section.settings.shop_label | default: 'Shop hats' | escape }}
      </a>
      <span class="rm-brand-commerce-sep" aria-hidden="true">·</span>
      <a
        href="{{ section.settings.hat_finder_link | default: 'https://hatfinder.moonridgecompany.com' }}"
        class="rm-brand-commerce-link"
      >
        {{ section.settings.hat_finder_label | default: 'Hat Finder' | escape }}
      </a>
    </div>

    {% if section.settings.promo_button_text != blank %}
      <script id="anywhere_book_now_script" src="https://assets.setmore.com/integration/book-now/live/v1/anywhere-book-now.js" defer="defer"></script>
      <button id="Anywhere_button_iframe"
              class="rm-brand-promo-btn anywhere-book-now-button"
              data-booking-url="https://moonridgecompany.setmore.com"
              data-new-tab="false"
              style="cursor: pointer;">
        {{ section.settings.promo_button_text }}
      </button>
    {% endif %}
  </div>

  {%- comment -%} Mobile Search Icon {%- endcomment -%}
  <button class="rm-brand-switcher-search" id="rm-mobile-search-btn" aria-label="Search" style="display: none;">
    <svg aria-hidden="true" focusable="false" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path fill-rule="evenodd" clip-rule="evenodd" d="M11.03 11.68A5.784 5.784 0 112.85 3.5a5.784 5.784 0 018.18 8.18zm.26 1.12a6.78 6.78 0 11.72-.7l5.4 5.4a.5.5 0 11-.71.7l-5.41-5.4z" fill="currentColor"/>
    </svg>
  </button>

  {%- comment -%} Mobile Cart Icon (Rendered directly to prevent jerky loading) {%- endcomment -%}
  <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset rm-brand-switcher-cart" id="cart-icon-bubble-mobile" style="display: none;">
    {%- render 'icon-cart' -%}
    <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
    {%- if cart != empty -%}
      <div class="cart-count-bubble">
        {%- if cart.item_count < 100 -%}
          <span aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
        <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
      </div>
    {%- endif -%}
  </a>
</div>

<script>
  // Show the mobile cart icon + search icon on mobile devices
  (function() {
    if (window.innerWidth < 750) {
      var mobileCart = document.getElementById('cart-icon-bubble-mobile');
      if (mobileCart) mobileCart.style.display = 'flex';
      var mobileSearch = document.getElementById('rm-mobile-search-btn');
      if (mobileSearch) mobileSearch.style.display = 'flex';
    }
  })();
</script>

{%- comment -%} Mobile Search Overlay {%- endcomment -%}
<div class="rm-mobile-search-overlay" id="rm-search-overlay"></div>
<div class="rm-mobile-search-panel" id="rm-search-panel">
  <form action="{{ routes.search_url }}" method="get" class="rm-mobile-search-form" role="search">
    <input type="search" name="q" class="rm-mobile-search-input" placeholder="Search hats, brands, accessories..." autocomplete="off" autocorrect="off" autocapitalize="off">
    <button type="button" class="rm-mobile-search-close" id="rm-search-close" aria-label="Close search">
      <svg viewBox="0 0 18 17" fill="none"><path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor"/></svg>
    </button>
  </form>
</div>

<script>
  (function() {
    var searchBtn = document.getElementById('rm-mobile-search-btn');
    var searchPanel = document.getElementById('rm-search-panel');
    var searchOverlay = document.getElementById('rm-search-overlay');
    var searchClose = document.getElementById('rm-search-close');
    var searchInput = searchPanel ? searchPanel.querySelector('input') : null;

    function openSearch() {
      searchPanel.classList.add('is-open');
      searchOverlay.classList.add('is-open');
      setTimeout(function() { if (searchInput) searchInput.focus(); }, 350);
    }
    function closeSearch() {
      searchPanel.classList.remove('is-open');
      searchOverlay.classList.remove('is-open');
      if (searchInput) searchInput.value = '';
    }

    if (searchBtn) searchBtn.addEventListener('click', openSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);
    if (searchOverlay) searchOverlay.addEventListener('click', closeSearch);
  })();
</script>




{% schema %}
{
  "name": "Brand Switcher Tabs",
  "class": "section-brand-switcher",
  "settings": [
    {
      "type": "text",
      "id": "promo_button_text",
      "label": "Promo Button Text",
      "default": "Book A Free Hat Experience"
    },
    {
      "type": "url",
      "id": "promo_button_link",
      "label": "Promo Button Link"
    },
    {
      "type": "header",
      "content": "Commerce links (desktop)"
    },
    {
      "type": "text",
      "id": "shop_label",
      "label": "Shop link label",
      "default": "Shop hats"
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Shop link"
    },
    {
      "type": "text",
      "id": "hat_finder_label",
      "label": "Hat Finder link label",
      "default": "Hat Finder"
    },
    {
      "type": "url",
      "id": "hat_finder_link",
      "label": "Hat Finder link"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Brand Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Name",
          "default": "Brand Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Tab Link"
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Is Active Tab?",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Switcher Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "title": "Moon Ridge",
            "is_active": true
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "Rafter M",
            "is_active": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
