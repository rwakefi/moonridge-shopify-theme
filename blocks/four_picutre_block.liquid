{% doc %}
  Picture grid: five images in one row on desktop; on smaller screens a 2-column grid with the fifth tile centered below.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-four-picture-grid-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-four-picture-grid__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px;
    text-align: {{ block.settings.title_alignment }};
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
  }

  .ai-four-picture-grid__container-{{ ai_gen_id }} {
    display: flex;
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    position: relative;
    /* Add fade masks to edges for premium feel */
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .ai-four-picture-grid__track-{{ ai_gen_id }} {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: {{ block.settings.spacing | times: 2 }}px;
    padding-right: {{ block.settings.spacing | times: 2 }}px;
    animation: scroll-marquee-{{ ai_gen_id }} 60s linear infinite;
  }

  .ai-four-picture-grid__container-{{ ai_gen_id }}:hover .ai-four-picture-grid__track-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  @keyframes scroll-marquee-{{ ai_gen_id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  .ai-four-picture-grid__item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: 180px;
    height: 100px;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_thickness }}px solid rgba({{ block.settings.border_color.red }}, {{ block.settings.border_color.green }}, {{ block.settings.border_color.blue }}, {{ block.settings.border_opacity | divided_by: 100.0 }});
  }

  .ai-four-picture-grid__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-four-picture-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ai-four-picture-grid__link-{{ ai_gen_id }}:hover .ai-four-picture-grid__image-{{ ai_gen_id }} {
    transform: scale(1.05);
    opacity: 0.8;
  }

  .ai-four-picture-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-four-picture-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.1;
  }

  .ai-four-picture-grid__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #999;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-four-picture-grid-{{ ai_gen_id }} {
      padding-left: 0;
      padding-right: 0;
    }
    
    .ai-four-picture-grid__track-{{ ai_gen_id }} {
      gap: 30px;
      padding-right: 30px;
      animation: scroll-marquee-{{ ai_gen_id }} 45s linear infinite;
    }

    .ai-four-picture-grid__item-{{ ai_gen_id }} {
      width: 130px;
      height: 80px;
    }
  }
{% endstyle %}

<div class="ai-four-picture-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h2 class="ai-four-picture-grid__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-four-picture-grid__container-{{ ai_gen_id }}">
    <!-- First Track -->
    <div class="ai-four-picture-grid__track-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign link_key = 'link_' | append: i
          assign image = block.settings[image_key]
          assign link = block.settings[link_key]
        %}

        <div class="ai-four-picture-grid__item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-four-picture-grid__link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-four-picture-grid__link-{{ ai_gen_id }}">
          {% endif %}

            {% if image %}
              <img
                src="{{ image | image_url: width: 400 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-four-picture-grid__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-four-picture-grid__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

          {% if link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    
    <!-- Duplicate Track for Seamless Scrolling -->
    <div class="ai-four-picture-grid__track-{{ ai_gen_id }}" aria-hidden="true">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign link_key = 'link_' | append: i
          assign image = block.settings[image_key]
          assign link = block.settings[link_key]
        %}

        <div class="ai-four-picture-grid__item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-four-picture-grid__link-{{ ai_gen_id }}" tabindex="-1">
          {% else %}
            <div class="ai-four-picture-grid__link-{{ ai_gen_id }}">
          {% endif %}

            {% if image %}
              <img
                src="{{ image | image_url: width: 400 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-four-picture-grid__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-four-picture-grid__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

          {% if link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Five picture grid",
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop by Category"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1f1d24"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Space below title",
      "default": 24
    },

    {
      "type": "header",
      "content": "Image 1"
    },
    { "type": "image_picker", "id": "image_1", "label": "Image" },
    { "type": "url", "id": "link_1", "label": "Link" },

    {
      "type": "header",
      "content": "Image 2"
    },
    { "type": "image_picker", "id": "image_2", "label": "Image" },
    { "type": "url", "id": "link_2", "label": "Link" },

    {
      "type": "header",
      "content": "Image 3"
    },
    { "type": "image_picker", "id": "image_3", "label": "Image" },
    { "type": "url", "id": "link_3", "label": "Link" },

    {
      "type": "header",
      "content": "Image 4"
    },
    { "type": "image_picker", "id": "image_4", "label": "Image" },
    { "type": "url", "id": "link_4", "label": "Link" },

    {
      "type": "header",
      "content": "Image 5"
    },
    { "type": "image_picker", "id": "image_5", "label": "Image" },
    { "type": "url", "id": "link_5", "label": "Link" },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Space between images",
      "default": 16
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "16 / 9", "label": "Wide (16:9)" }
      ],
      "default": "1 / 1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Corner radius",
      "default": 8
    },

    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "min": 0,
      "max": 12,
      "step": 1,
      "unit": "px",
      "label": "Thickness",
      "default": 0
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Opacity",
      "default": 10
    },

    {
      "type": "header",
      "content": "Colors and spacing"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding left/right",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Five picture grid"
    }
  ]
}
{% endschema %}