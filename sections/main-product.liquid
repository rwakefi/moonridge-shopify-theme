                  }
            
                  70% {
                      transform: scale(1);
                      box-shadow: 0 0 0 3px rgba(236,0,140,0);
                  }
            
                  100% {
                      transform: scale(.95);
                      box-shadow: 0 0 0 0 rgba(236,0,140,0);
                  }
