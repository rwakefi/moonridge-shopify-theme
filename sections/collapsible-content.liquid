<section class="rm-faq section-{{ section.id }}">
  <div class="rm-faq-inner page-width">
    {% if section.settings.heading != blank %}
      <h2 class="rm-faq-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="rm-faq-items">
      <!-- FAQ 1 -->
      <details class="rm-faq-item" open>
        <summary class="rm-faq-question">
          How do I know what hat size I need?
        </summary>
        <div class="rm-faq-answer">
          <p>
            If you’re local, stop by our Fayetteville showroom and we’ll size you in person.
            Not local? There is a sizing video and chart on each hat page to help you find the right size.  Need some help? Book a virtual sizing appointment and we’ll walk you through measuring
            your head and help you pick the right size and shape for your style.
          </p>
        </div>
      </details>

      <!-- FAQ 2 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          Do you shape hats in-store?
        </summary>
        <div class="rm-faq-answer">
          <p>
            Yes. Our hat shapers are in-house on
            <strong>Thursday &amp; Friday, 10:00am–5:00pm</strong> and
            <strong>Saturday, 10:00am–2:00pm</strong>. We offer custom shaping, steaming,
            cleaning, and touch-ups to get your hat looking just the way you like it.
          </p>
        </div>
      </details>

      <!-- FAQ 3 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          Can you clean or reshape an old hat?
        </summary>
        <div class="rm-faq-answer">
          <p>
            YES! Bring your hat in (or ship it to us) and we’ll get you fixed up!  
            We can usually refresh the shape, clean the brim and crown, and bring some life
            back into a well-loved hat. Extremely damaged hats may have limits, but we’ll be
            honest about what’s possible before we start.
          </p>
        </div>
      </details>

      <!-- FAQ 4 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          Do you customize hat bands and accessories?
        </summary>
        <div class="rm-faq-answer">
          <p>
            Absolutely. We style hats with ribbons, leather bands, feathers, matchbooks, pins,
            and seasonal accents. You can bring your own inspiration or let us design something
            unique that fits your look.
          </p>
        </div>
      </details>

      <!-- FAQ 5 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          Do you ship hats?
        </summary>
        <div class="rm-faq-answer">
          <p>
            Yes, we ship nationwide!  Shipping options and pricing are shown at checkout, and we’ll pack your
            hat carefully so it arrives ready to wear.
          </p>
        </div>
      </details>

      <!-- FAQ 6 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          What is your return or exchange policy?
        </summary>
        <div class="rm-faq-answer">
          <p>
            Unworn, unaltered hats in original condition may typically be returned or exchanged
            within the timeframe listed in our official
            <a href="/policies/refund-policy">Refund Policy</a>. Because custom shaping,
            branding, and personalization are done just for you, those services and customized
            hats are final sale.  
          </p>
        </div>
      </details>

      <!-- FAQ 7 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          I’m not local. Can I still get help choosing a hat?
        </summary>
        <div class="rm-faq-answer">
          <p>
            Yes. You can book a virtual consultation and we’ll meet with you over video.
            We’ll talk through your style, how you plan to wear the hat, sizing, and shape
            options, then send you a curated list of recommendations you can purchase online.
          </p>
        </div>
      </details>

      <!-- FAQ 8 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          Do you offer private hat parties or events?
        </summary>
        <div class="rm-faq-answer">
          <p>
            We do. The <strong>Rafter M Hat Experience</strong> is available for bridal parties,
            birthdays, corporate events, and group celebrations. We can host in-store or bring
            our mobile hat bar to your venue, with custom fittings, shaping, and accessories
            for each guest.
          </p>
          <p>
            To start planning, reach out to us at
            <a href="mailto:info@raftermhatco.com">info@raftermhatco.com</a>.
          </p>
        </div>
      </details>

      <!-- FAQ 9 -->
      <details class="rm-faq-item">
        <summary class="rm-faq-question">
          Where are you located and what are your hours?
        </summary>
        <div class="rm-faq-answer">
          <p>
            We’re located at <strong>2218 N College Avenue, Fayetteville, AR 72703</strong>.
          </p>
          <p>
            Retail Shop Hours:<br>
            Mon–Fri: 10:00am–5:00pm<br>
            Saturday: 10:00am–2:00pm<br>
            Sunday: Closed<br>
            <p>
            Our Hat Shapers are in House:<br>
            Thursday & Friday 10:00am - 5:00pm<br>
            Saturday 10:00am - 2:00pm<br><p>
            Hours may vary best on Private Events
            </p>
            </p>
          </p>
        </div>
      </details>
    </div>
  </div>
</section>

{% style %}
  .rm-faq.section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .rm-faq-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .rm-faq-heading {
    text-align: center;
    font-size: 28px;
    letter-spacing: 1px;
    margin-bottom: 32px;
    text-transform: uppercase;
  }

  .rm-faq-items {
    border-top: 1px solid #ddd;
  }

  .rm-faq-item {
    border-bottom: 1px solid #ddd;
    padding: 14px 0;
  }

  .rm-faq-question {
    list-style: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .rm-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .rm-faq-answer {
    margin-top: 10px;
    font-size: 15px;
    line-height: 1.6;
  }

  .rm-faq-answer a {
    text-decoration: underline;
  }
{% endstyle %}

{% schema %}
{
  "name": "FAQ accordion",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion"
    }
  ]
}
{% endschema %}