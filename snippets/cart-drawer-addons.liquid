{% comment %}
  Suggested add-ons for the cart drawer.
  Renders products from a merchant-picked collection (Theme settings > Cart),
  excluding anything already in the cart. Re-renders with the drawer on every
  cart change, so added items disappear from the list automatically.

  Single-variant products add directly via <product-form> (AJAX, refreshes the
  drawer). Multi-variant products link to the product page to choose options.

  Usage:
  {% render 'cart-drawer-addons' %}
{% endcomment %}

{%- liquid
  assign addons_collection = settings.cart_addons_collection
  assign limit = settings.cart_addons_limit | default: 6
  assign addons_enabled = settings.cart_addons_enable
  if addons_enabled == blank
    assign addons_enabled = true
  endif
-%}

{%- if addons_enabled and cart != empty and addons_collection != blank and addons_collection.products_count > 0 -%}
  {%- comment -%} Build a lookup of product ids already in the cart {%- endcomment -%}
  {%- assign cart_product_ids = cart.items | map: 'product_id' -%}

  {%- assign rendered = 0 -%}
  {%- capture addon_items -%}
    {%- for product in addons_collection.products -%}
      {%- if rendered >= limit -%}{%- break -%}{%- endif -%}
      {%- unless cart_product_ids contains product.id -%}
        {%- unless product.available == false -%}
          {%- assign rendered = rendered | plus: 1 -%}
          {%- liquid
            assign variant = product.selected_or_first_available_variant
            assign needs_options = false
            if product.variants.size > 1 or variant.quantity_rule.min > 1 or variant.quantity_rule.max != null or variant.quantity_rule.increment > 1
              assign needs_options = true
            endif
            assign form_id = 'CartAddon-' | append: product.id
          -%}
          <li class="cart-addons__item">
            <a href="{{ product.url }}" class="cart-addons__media" tabindex="-1" aria-hidden="true">
              {%- if product.featured_media -%}
                <img
                  src="{{ product.featured_media | image_url: width: 260 }}"
                  alt="{{ product.featured_media.alt | escape }}"
                  loading="lazy"
                  width="130"
                  height="130"
                >
              {%- endif -%}
            </a>
            <a href="{{ product.url }}" class="cart-addons__title">{{ product.title | escape }}</a>
            <span class="cart-addons__price">
              {%- if product.price_varies -%}
                {{ 'products.product.price.from_price_html' | t: price: product.price_min | money }}
              {%- else -%}
                {{ product.price | money }}
              {%- endif -%}
            </span>
            <div class="cart-addons__add">
              {%- if needs_options -%}
                <a href="{{ product.url }}" class="button button--secondary cart-addons__choose">
                  {{ 'products.product.choose_options' | t }}
                </a>
              {%- else -%}
                <product-form data-section-id="cart-drawer">
                  {%- form 'product',
                    product,
                    id: form_id,
                    class: 'form',
                    novalidate: 'novalidate',
                    data-type: 'add-to-cart-form'
                  -%}
                    <input
                      type="hidden"
                      name="id"
                      value="{{ variant.id }}"
                      class="product-variant-id"
                    >
                    <button
                      type="submit"
                      name="add"
                      class="button button--secondary cart-addons__add-button"
                      aria-haspopup="dialog"
                    >
                      <span>{{ 'products.product.add_to_cart' | t }}</span>
                      {%- render 'loading-spinner' -%}
                    </button>
                    <div class="product-form__error-message-wrapper" role="alert" hidden>
                      <span class="product-form__error-message"></span>
                    </div>
                  {%- endform -%}
                </product-form>
              {%- endif -%}
            </div>
          </li>
        {%- endunless -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endcapture -%}

  {%- if rendered > 0 -%}
    {%- comment -%}
      product-form.js defines the <product-form> element used by the add buttons.
      It's only loaded on product/collection pages by default, so load it here too
      (the script self-guards against double definition).
    {%- endcomment -%}
    <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
    <div class="cart-addons">
      {%- if settings.cart_addons_heading != blank -%}
        <p class="cart-addons__heading">{{ settings.cart_addons_heading | escape }}</p>
      {%- endif -%}
      <ul class="cart-addons__list" role="list">
        {{ addon_items }}
      </ul>
    </div>
  {%- endif -%}
{%- endif -%}
