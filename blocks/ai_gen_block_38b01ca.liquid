{% doc %}
  @prompt
    A heading matching and a slider that varies the font size and then a body paragraph 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-block-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-block__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing_below_heading }}px;
    line-height: 1.2;
    font-weight: 500;
  }

  .ai-text-block__paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size }}px;
    color: {{ block.settings.paragraph_color }};
    line-height: 1.6;
    margin: 0;
    max-width: {{ block.settings.paragraph_max_width }}px;
  }

  .ai-text-block__paragraph-{{ ai_gen_id }}--center {
    margin-left: auto;
    margin-right: auto;
  }

  .ai-text-block__paragraph-{{ ai_gen_id }}--right {
    margin-left: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-text-block__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-text-block__paragraph-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.paragraph_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-text-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-text-block__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  {% if block.settings.paragraph != blank %}
    <div class="ai-text-block__paragraph-{{ ai_gen_id }} ai-text-block__paragraph-{{ ai_gen_id }}--{{ block.settings.text_alignment }}">
      {{ block.settings.paragraph }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Text with font slider",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Premium Headwear"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading font size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1f1d24"
    },
    {
      "type": "range",
      "id": "spacing_below_heading",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Space below heading",
      "default": 16
    },
    {
      "type": "header",
      "content": "Paragraph"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Paragraph text",
      "default": "<p>Crafted with precision and designed for those who appreciate quality, our collection brings together heritage-inspired style and modern craftsmanship.</p>"
    },
    {
      "type": "range",
      "id": "paragraph_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Paragraph font size",
      "default": 16
    },
    {
      "type": "color",
      "id": "paragraph_color",
      "label": "Paragraph color",
      "default": "#1f1d24"
    },
    {
      "type": "range",
      "id": "paragraph_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Paragraph max width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Text with font slider"
    }
  ]
}
{% endschema %}