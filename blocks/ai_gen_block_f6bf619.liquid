{% doc %}
  @prompt
    a section the same size as the lumen slideshow section below, this will just be a single picture, it needs to be 1920 by 1080, add a mobile image that is 1080 by 1350
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-single-image-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-single-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
  }

  .ai-single-image-img-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-single-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  {% if block.settings.desktop_image %}
    .ai-single-image-img-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.desktop_image.aspect_ratio }};
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-single-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 1080 / 1350;
    }

    {% if block.settings.desktop_image %}
      .ai-single-image-img-{{ ai_gen_id }} {
        aspect-ratio: {{ block.settings.mobile_image.aspect_ratio | default: block.settings.desktop_image.aspect_ratio }};
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-single-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-single-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      {% assign desktop_image = block.settings.desktop_image %}
      {% assign mobile_image = block.settings.mobile_image | default: desktop_image %}

      {% assign desktop_widths = '750,1100,1500,1780,1920' | split: ',' %}
      {% assign mobile_widths = '400,550,750,900,1080' | split: ',' %}

      {% capture desktop_srcset %}
        {%- assign first = true -%}
        {%- for w in desktop_widths -%}
          {%- assign w_num = w | plus: 0 -%}
          {%- if w_num <= desktop_image.width -%}
            {%- unless first -%}, {% endunless -%}{{ desktop_image | image_url: width: w_num }} {{ w_num }}w
            {%- assign first = false -%}
          {%- endif -%}
        {%- endfor -%}
      {% endcapture %}

      {% capture mobile_srcset %}
        {%- assign first = true -%}
        {%- for w in mobile_widths -%}
          {%- assign w_num = w | plus: 0 -%}
          {%- if w_num <= mobile_image.width -%}
            {%- unless first -%}, {% endunless -%}{{ mobile_image | image_url: width: w_num }} {{ w_num }}w
            {%- assign first = false -%}
          {%- endif -%}
        {%- endfor -%}
      {% endcapture %}

      <picture>
        <source
          media="(max-width: 749px)"
          srcset="{{ mobile_srcset | strip }}"
          sizes="100vw"
        >
        <img
          src="{{ desktop_image | image_url: width: 1920 }}"
          srcset="{{ desktop_srcset | strip }}"
          sizes="100vw"
          alt="{{ desktop_image.alt | escape }}"
          loading="eager"
          fetchpriority="high"
          width="{{ desktop_image.width }}"
          height="{{ desktop_image.height }}"
          class="ai-single-image-img-{{ ai_gen_id }}"
        >
      </picture>
    {% else %}
      <div class="ai-single-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-single-image-empty-state-{{ ai_gen_id }}">
          Add a desktop image (1920 x 1080)
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Single image",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended size: 1920 x 1080 pixels"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended size: 1080 x 1350 pixels. If not set, desktop image will be used."
    }
  ],
  "presets": [
    {
      "name": "Single image"
    }
  ],
  "tag": null
}
{% endschema %}