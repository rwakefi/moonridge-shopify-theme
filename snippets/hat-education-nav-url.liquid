{% comment %}
  Correct Hat Education submenu URLs (admin menu may duplicate the face-shape link).
  Outputs the URL string (use with capture in parent).

  Usage:
  {% capture hat_education_nav_url %}{% render 'hat-education-nav-url', link: childlink %}{% endcapture %}
{% endcomment %}
{%- liquid
  assign hat_education_nav_url = link.url
  assign link_title_lc = link.title | downcase | strip
  assign link_handle = link.handle | downcase

  if link_handle == 'learn-your-head-shape' or link_title_lc contains 'learn your head'
    assign hat_education_nav_url = '/blogs/hat-education/learn-your-head-shape'
  elsif link_handle == 'hats-and-your-face-shape' or link_handle contains 'face-shape' or link_title_lc contains 'face shape'
    assign hat_education_nav_url = '/blogs/hat-education/finding-the-style-that-fits-your-face'
  endif
-%}{{- hat_education_nav_url -}}

