{% comment %}
  Hats hub tile image: manual upload → product metafield match → collection image.
  @param block_image - image_picker from block settings
  @param image_metafield_key - key under custom.* (e.g. western)
  @param collection_all, collection_men, collection_women - collection objects
  @param metafield_search_collection - section fallback to scan for metafield matches
  @param title - tile label for alt fallback
{% endcomment %}
{%- liquid
  assign tile_image = block_image
  assign mf_key = image_metafield_key | strip

  if tile_image == blank and mf_key != blank
    assign search_collections = collection_all | append: ''

    if collection_all != blank
      for product in collection_all.products limit: 50
        if mf_key == 'western'
          assign product_mf = product.metafields.custom.western
        else
          assign product_mf = product.metafields.custom[mf_key]
        endif

        assign mf_match = false
        if product_mf.value == true or product_mf == true
          assign mf_match = true
        elsif product_mf != blank and product_mf.value != false and product_mf.value != blank
          assign mf_match = true
        endif

        if mf_match
          if product.featured_media != blank
            assign tile_image = product.featured_media.preview_image
            break
          elsif product.featured_image != blank
            assign tile_image = product.featured_image
            break
          endif
        endif
      endfor
    endif

    if tile_image == blank and collection_men != blank
      for product in collection_men.products limit: 50
        if mf_key == 'western'
          assign product_mf = product.metafields.custom.western
        else
          assign product_mf = product.metafields.custom[mf_key]
        endif
        assign mf_match = false
        if product_mf.value == true or product_mf == true
          assign mf_match = true
        elsif product_mf != blank and product_mf.value != false and product_mf.value != blank
          assign mf_match = true
        endif
        if mf_match
          if product.featured_media != blank
            assign tile_image = product.featured_media.preview_image
            break
          elsif product.featured_image != blank
            assign tile_image = product.featured_image
            break
          endif
        endif
      endfor
    endif

    if tile_image == blank and collection_women != blank
      for product in collection_women.products limit: 50
        if mf_key == 'western'
          assign product_mf = product.metafields.custom.western
        else
          assign product_mf = product.metafields.custom[mf_key]
        endif
        assign mf_match = false
        if product_mf.value == true or product_mf == true
          assign mf_match = true
        elsif product_mf != blank and product_mf.value != false and product_mf.value != blank
          assign mf_match = true
        endif
        if mf_match
          if product.featured_media != blank
            assign tile_image = product.featured_media.preview_image
            break
          elsif product.featured_image != blank
            assign tile_image = product.featured_image
            break
          endif
        endif
      endfor
    endif

    if tile_image == blank and metafield_search_collection != blank
      for product in metafield_search_collection.products limit: 50
        if mf_key == 'western'
          assign product_mf = product.metafields.custom.western
        else
          assign product_mf = product.metafields.custom[mf_key]
        endif
        assign mf_match = false
        if product_mf.value == true or product_mf == true
          assign mf_match = true
        elsif product_mf != blank and product_mf.value != false and product_mf.value != blank
          assign mf_match = true
        endif
        if mf_match
          if product.featured_media != blank
            assign tile_image = product.featured_media.preview_image
            break
          elsif product.featured_image != blank
            assign tile_image = product.featured_image
            break
          endif
        endif
      endfor
    endif
  endif

  if tile_image == blank and collection_all != blank and collection_all.image != blank
    assign tile_image = collection_all.image
  elsif tile_image == blank and collection_men != blank and collection_men.image != blank
    assign tile_image = collection_men.image
  elsif tile_image == blank and collection_women != blank and collection_women.image != blank
    assign tile_image = collection_women.image
  endif

  if tile_image == blank and collection_all != blank
    for product in collection_all.products limit: 12
      if product.featured_media != blank
        assign tile_image = product.featured_media.preview_image
        break
      elsif product.featured_image != blank
        assign tile_image = product.featured_image
        break
      endif
    endfor
  endif
-%}
{%- if tile_image != blank -%}
  {{
    tile_image
    | image_url: width: 800
    | image_tag:
      loading: 'lazy',
      sizes: '(min-width: 990px) 280px, (min-width: 750px) 33vw, 45vw',
      widths: '300, 400, 500, 600, 800',
      alt: tile_image.alt | default: title | escape
  }}
{%- else -%}
  {{ 'collection-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
{%- endif -%}
