      "default": "QUICK LINKS"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Quick links menu",
      "default": "footer"
    },
    {
      "type": "textarea",
      "id": "bottom_text",
      "label": "Bottom bar text",
      "default": "© 2026 Moon Ridge Company (formerly Rafter M Hat Co.)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
