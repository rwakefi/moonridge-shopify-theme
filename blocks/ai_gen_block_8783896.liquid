{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-metadata-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-category-metadata-grid-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: {{ block.settings.gap }}px;
  }

  .ai-category-metadata-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    width: calc((100% / {{ block.settings.columns_desktop }}) - {{ block.settings.gap }}px);
    min-width: 200px;
  }

  .ai-category-metadata-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
  }

  .ai-category-metadata-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_size }}px;
    font-weight: {{ block.settings.value_weight }};
    color: {{ block.settings.value_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-category-metadata-item-{{ ai_gen_id }} {
      width: calc((100% / {{ block.settings.columns_mobile }}) - {{ block.settings.gap }}px);
      min-width: 0;
    }
    
    .ai-category-metadata-item-{{ ai_gen_id }}:nth-child(odd):last-child {
      grid-column: auto;
      max-width: 100%;
      margin: 0 auto;
    }
  }
{% endstyle %}

<category-metadata-{{ ai_gen_id }}
  class="ai-category-metadata-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-category-metadata-grid-{{ ai_gen_id }}">
    {% liquid
      assign crown_shape = product.metafields.custom.crown_shape.value
      if crown_shape == blank
        assign crown_shape = block.settings.category_1_fallback
      endif
    %}
    
    {% if crown_shape != blank and block.settings.category_1_title != blank %}
      <div class="ai-category-metadata-item-{{ ai_gen_id }}">
        <h3 class="ai-category-metadata-title-{{ ai_gen_id }}">{{ block.settings.category_1_title }}</h3>
        <p class="ai-category-metadata-value-{{ ai_gen_id }}">{{ crown_shape }}</p>
      </div>
    {% endif %}

    {% for i in (2..4) %}
      {% liquid
        assign title_key = 'category_' | append: i | append: '_title'
        assign value_key = 'category_' | append: i | append: '_value'
        
        assign title = block.settings[title_key]
        assign value = block.settings[value_key] | strip
      %}
      
      {% if title != blank and value != blank and value != '-' and value != ' ' %}
        <div class="ai-category-metadata-item-{{ ai_gen_id }}">
          <h3 class="ai-category-metadata-title-{{ ai_gen_id }}">{{ title }}</h3>
          <p class="ai-category-metadata-value-{{ ai_gen_id }}">{{ value }}</p>
        </div>
      {% endif %}
    {% endfor %}

    {% comment %} New Conditional Fields for Rafter M Premium Specs {% endcomment %}
    {%- liquid
      assign mat_quality = product.metafields.custom.material_quality.value | join: ', '
      if mat_quality == blank
        assign mat_quality = product.metafields.custom.material_quality
      endif
      
      assign origin = product.metafields.custom.origin.value | join: ', '
      if origin == blank
        assign origin = product.metafields.custom.origin
      endif
    -%}

    {%- if mat_quality != blank -%}
      <div class="ai-category-metadata-item-{{ ai_gen_id }}">
        <h3 class="ai-category-metadata-title-{{ ai_gen_id }}">Material Quality</h3>
        <p class="ai-category-metadata-value-{{ ai_gen_id }}">{{ mat_quality }}</p>
      </div>
    {%- endif -%}

    {%- if origin != blank -%}
      <div class="ai-category-metadata-item-{{ ai_gen_id }}">
        <h3 class="ai-category-metadata-title-{{ ai_gen_id }}">Origin</h3>
        <p class="ai-category-metadata-value-{{ ai_gen_id }}">{{ origin }}</p>
      </div>
    {%- endif -%}
  </div>
</category-metadata-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryMetadata{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('category-metadata-{{ ai_gen_id }}', CategoryMetadata{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Category metadata",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Container style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Item style"
    },
    {
      "type": "color",
      "id": "item_background_color",
      "label": "Background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "item_border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "item_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "item_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#1f1d24"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Spacing below title",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Value style"
    },
    {
      "type": "range",
      "id": "value_size",
      "label": "Size",
      "min": 12,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "value_weight",
      "label": "Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "value_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Category 1 - Crown Shape"
    },
    {
      "type": "text",
      "id": "category_1_title",
      "label": "Title",
      "default": "Crown Shape"
    },
    {
      "type": "text",
      "id": "category_1_fallback",
      "label": "Fallback value",
      "info": "Shown when product.metafields.custom.crown_shape is empty"
    },
    {
      "type": "header",
      "content": "Category 2"
    },
    {
      "type": "text",
      "id": "category_2_title",
      "label": "Title",
      "default": "Material"
    },
    {
      "type": "text",
      "id": "category_2_value",
      "label": "Value",
      "default": "Wool Felt"
    },
    {
      "type": "header",
      "content": "Category 3"
    },
    {
      "type": "text",
      "id": "category_3_title",
      "label": "Title",
      "default": "Style"
    },
    {
      "type": "text",
      "id": "category_3_value",
      "label": "Value",
      "default": "Western"
    },
    {
      "type": "header",
      "content": "Category 4"
    },
    {
      "type": "text",
      "id": "category_4_title",
      "label": "Title",
      "default": "Origin"
    },
    {
      "type": "text",
      "id": "category_4_value",
      "label": "Value",
      "default": "Made in USA"
    }
  ],
  "presets": [
    {
      "name": "Category metadata"
    }
  ]
