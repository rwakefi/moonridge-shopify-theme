{%- liquid
  assign intro = section.settings.intro
-%}

<section class="rm-faq section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="rm-faq-inner page-width" style="max-width: {{ section.settings.content_max_width }}px;">
    {% if section.settings.heading != blank %}
      <h2 class="rm-faq-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if intro != blank %}
      <div class="rm-faq-intro rte">{{ intro }}</div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="rm-faq-items">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'category' -%}
              {% if block.settings.title != blank %}
                <h3 class="rm-faq-category" {{ block.shopify_attributes }}>{{ block.settings.title }}</h3>
              {% endif %}
            {%- when 'item' -%}
              <details class="rm-faq-item" {{ block.shopify_attributes }}>
                <summary class="rm-faq-question">
                  <span>{{ block.settings.question }}</span>
                  <span class="rm-faq-chevron" aria-hidden="true"></span>
                </summary>
                <div class="rm-faq-answer rte">
                  {{ block.settings.answer }}
                </div>
              </details>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {% endif %}
  </div>
</section>

{% style %}
  .rm-faq.section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .rm-faq-inner {
    margin: 0 auto;
  }

  .rm-faq-heading {
    text-align: {{ section.settings.heading_alignment }};
    font-size: clamp(1.75rem, 2vw + 1rem, {{ section.settings.heading_size }}px);
    letter-spacing: 0.06em;
    margin: 0 0 1rem;
    text-transform: uppercase;
    font-family: var(--font-heading-family);
    color: rgb(var(--color-foreground));
  }

  .rm-faq-intro {
    text-align: {{ section.settings.heading_alignment }};
    margin: 0 auto 2.5rem;
    max-width: 48rem;
    font-size: 1.5rem;
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.85);
  }

  .rm-faq-items {
    border-top: 1px solid rgba(var(--color-foreground), 0.12);
  }

  .rm-faq-category {
    margin: 2.5rem 0 1rem;
    padding-top: 0.5rem;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    font-family: var(--font-heading-family);
    color: rgb(var(--color-foreground));
  }

  .rm-faq-items > .rm-faq-category:first-child {
    margin-top: 0;
    padding-top: 0;
  }

  .rm-faq-item {
    border-bottom: 1px solid rgba(var(--color-foreground), 0.12);
    padding: 0;
  }

  .rm-faq-question {
    list-style: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 1.4rem 0;
    color: rgb(var(--color-foreground));
  }

  .rm-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .rm-faq-chevron {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    margin-top: -0.35rem;
    opacity: 0.65;
    transition: transform 0.2s ease;
  }

  .rm-faq-item[open] .rm-faq-chevron {
    transform: rotate(225deg);
    margin-top: 0.25rem;
  }

  .rm-faq-answer {
    padding: 0 0 1.6rem;
    font-size: 1.45rem;
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.88);
  }

  .rm-faq-answer a {
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  @media screen and (max-width: 749px) {
    .rm-faq-question {
      font-size: 1.35rem;
      padding: 1.2rem 0;
    }
    .rm-faq-answer {
      font-size: 1.35rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "FAQ accordion",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size (desktop max)",
      "default": 36
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "info": "Optional text below the heading (hours, contact, etc.)"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 600,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 900
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "General"
        }
      ]
    },
    {
      "type": "item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your question?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Add a clear answer here. You can use links, bold text, and short lists.</p>"
        }
      ]
    }
  ],
  "max_blocks": 80,
  "presets": [
    {
      "name": "FAQ accordion",
      "blocks": [
        {
          "type": "category",
          "settings": { "title": "Shopping with us" }
        },
        {
          "type": "item",
          "settings": {
            "question": "Do you ship hats?",
            "answer": "<p>Yes — we ship nationwide. Shipping options appear at checkout, and we pack hats carefully so they arrive ready to wear.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "How do I find my hat size?",
            "answer": "<p>Visit us in Fayetteville for an in-person fitting, or use the sizing resources on each hat product page. You can also book a virtual consultation for one-on-one help.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
