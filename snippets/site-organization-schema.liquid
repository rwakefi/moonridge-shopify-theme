{%- liquid
  assign social_profiles = ''
  if settings.social_facebook_link != blank
    assign social_profiles = social_profiles | append: settings.social_facebook_link | json
  endif
  if settings.social_instagram_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_instagram_link | json
  endif
  if settings.social_youtube_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_youtube_link | json
  endif
  if settings.social_twitter_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_twitter_link | json
  endif
  if settings.social_pinterest_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_pinterest_link | json
  endif
  if settings.social_tiktok_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_tiktok_link | json
  endif
  if settings.social_snapchat_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_snapchat_link | json
  endif
  if settings.social_tumblr_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_tumblr_link | json
  endif
  if settings.social_vimeo_link != blank
    if social_profiles != blank
      assign social_profiles = social_profiles | append: ','
    endif
    assign social_profiles = social_profiles | append: settings.social_vimeo_link | json
  endif
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": {{ request.origin | append: "/#organization" | json }},
      "name": {{ shop.name | json }},
      "url": {{ request.origin | json }},
      "alternateName": ["Rafter M Hat Company", "Rafter M", "Moon Ridge"],
      "description": "Moon Ridge Company, formerly Rafter M Hat Company, is Northwest Arkansas' premier destination for headwear, premium apparel, hat shaping, and hat cleaning. Located in Fayetteville, AR, we carry heritage brands including Stetson, Resistol, and Pendleton. Exact same people, exact same hands — simply expanding our offerings.",
      {% if settings.logo != blank %}
        "logo": {{ settings.logo | image_url: width: 600 | prepend: "https:" | json }},
      {% endif %}
      {% if shop.phone != blank %}
        "telephone": {{ shop.phone | json }},
      {% endif %}
      "foundingDate": "2019",
      "sameAs": [
        {%- if social_profiles != blank -%}{{ social_profiles }},{%- endif -%}
        "https://www.raftermhatco.com",
        "https://raftermhatco.com"
      ],
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "url": {{ request.origin | append: routes.contact_url | json }}
        }
      ]
    },
    {
      "@type": "LocalBusiness",
      "name": {{ shop.name | json }},
      "alternateName": ["Rafter M Hat Company", "Rafter M"],
      "image": {{ "Moon_Ridge_Storefront.jpg" | asset_url | prepend: "https:" | json }},
      "@id": {{ request.origin | append: "/#localbusiness" | json }},
      "url": {{ request.origin | json }},
      "telephone": "(479) 430-2667",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "2218 N College Ave",
        "addressLocality": "Fayetteville",
        "addressRegion": "AR",
        "postalCode": "72703",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 36.0921,
        "longitude": -94.1531
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "10:00",
          "closes": "18:00"
        }
      ],
      "sameAs": [
        {%- if social_profiles != blank -%}{{ social_profiles }},{%- endif -%}
        "https://www.raftermhatco.com",
        "https://raftermhatco.com"
      ]
    }
  ]
}
</script>

{%- assign search_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ request.origin | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": {{ search_action_target | json }},
    "query-input": "required name=search_term_string"
  }
}
</script>
