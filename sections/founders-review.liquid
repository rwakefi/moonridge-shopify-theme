{%- if product.metafields.custom.zack_and_natalie_s_word_s != blank -%}
  {%- style -%}
    @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');
    
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    .founders-review {
      background-color: #FDF9F3; /* Warm Ivory Stationery */
      color: {{ section.settings.text_color }};
      border-radius: {{ section.settings.border_radius }}px;
      border: 1px solid #E8D9C8;
      position: relative;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .founders-review::after {
      content: '';
      position: absolute;
      top: 10px;
      left: 10px;
      right: 10px;
      bottom: 10px;
      border: 1px solid rgba(74, 46, 31, 0.05); /* Subtle inner rule */
      border-radius: {{ section.settings.border_radius | minus: 4 | max: 0 }}px;
      pointer-events: none;
    }

    .founders-review__container {
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
      padding: 2rem;
    }

    .founders-review__heading {
      color: #4A2E1F;
      font-size: {{ section.settings.heading_size }}px;
      margin: 0 0 1.5rem 0;
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .founders-review__intro {
      font-style: italic;
      font-size: 0.9em;
      opacity: 0.8;
      margin-bottom: 1rem;
      border-bottom: 1px solid rgba(74, 46, 31, 0.1);
      padding-bottom: 0.8rem;
      color: #7A604A;
    }

    .founders-review__content {
      line-height: 1.8;
      font-size: 1.15em;
      font-family: 'Playfair Display', serif;
      color: #312110;
    }

    .founders-review__content p:first-child {
      margin-top: 0;
    }

    .founders-review__signature {
      margin-top: 1.5rem;
      font-family: 'Dancing Script', cursive;
      font-size: 2.8rem;
      color: #4A2E1F;
      text-align: {{ section.settings.signature_alignment }};
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .founders-review__signature-tagline {
      font-family: var(--font-body-family);
      font-size: 0.45em;
      text-transform: uppercase;
      letter-spacing: 0.15rem;
      opacity: 0.6;
      margin-top: 0.3rem; /* Further tightened gap */
    }
    
    @media screen and (max-width: 749px) {
      .founders-review__heading {
        font-size: {{ section.settings.heading_size | times: 0.8 | round: 0 }}px;
      }
    }
  {%- endstyle -%}

  <div class="founders-review section-{{ section.id }}-padding">
    <div class="founders-review__container page-width">
      {%- if section.settings.heading != blank -%}
        <h2 class="founders-review__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.intro_text != blank -%}
        <div class="founders-review__intro rte">
          {{ section.settings.intro_text }}
        </div>
      {%- endif -%}

      <div class="founders-review__content rte">
        {{ product.metafields.custom.zack_and_natalie_s_word_s | metafield_tag }}
      </div>

      {%- if section.settings.show_signature -%}
        <div class="founders-review__signature">
          <div>{{ section.settings.signature_text }}</div>
          <div class="founders-review__signature-tagline">Founders, Rafter M Hat Co.</div>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Founders' Review",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Section Heading",
      "default": "What Natalie and Zack Think About it:"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 32
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Description / Intro",
      "default": "<p>This is honest feedback from founders Natalie and Zack about specific items that we have reviewed ourselves in our own words. If this section is visible, we describe what we think about this hat in our own words. This is not AI.</p>"
    },
    {
      "type": "header",
      "content": "Signature"
    },
    {
      "type": "checkbox",
      "id": "show_signature",
      "label": "Show handwritten signature",
      "default": true
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature Text",
      "default": "Natalie & Zack"
    },
    {
      "type": "select",
      "id": "signature_alignment",
      "label": "Signature Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1f1d24"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1f1d24"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum Width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Corner Radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Founders' Review"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
