{% doc %}
  @prompt
    a section the same size as the lumen slideshow section below, this will just be a single picture, it needs to be 1920 by 1080, add a mobile image that is 1080 by 1350
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-single-image-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-single-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
  }

  .ai-single-image-desktop-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-single-image-mobile-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-single-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-single-image-cta-{{ ai_gen_id }} {
    --mr-cta-band: {{ block.settings.cta_background | default: '#ffffff' }};
    --mr-cta-ink: {{ block.settings.cta_text_color | default: '#312110' }};
    --mr-cta-rule: {{ block.settings.cta_accent_color | default: '#c4b49a' }};
    --mr-btn-bg: {{ block.settings.button_background | default: '#312110' }};
    --mr-btn-text: {{ block.settings.button_text_color | default: '#ffffff' }};

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 20px 18px;
    background: var(--mr-cta-band);
    border-top: 1px solid color-mix(in srgb, var(--mr-cta-rule) 70%, transparent);
    text-align: center;
  }

  .ai-single-image-cta-copy-{{ ai_gen_id }} {
    margin: 0;
    color: var(--mr-cta-ink);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1.4;
    opacity: 0.78;
  }

  .ai-single-image-cta-actions-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
  }

  .ai-single-image-cta-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 44px;
    padding: 11px 22px;
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .ai-single-image-cta-btn-{{ ai_gen_id }} svg {
    width: 14px;
    height: 14px;
    transition: transform 0.2s ease;
  }

  .ai-single-image-cta-btn--primary-{{ ai_gen_id }} {
    color: var(--mr-btn-text);
    background-color: var(--mr-btn-bg);
    border: 1px solid var(--mr-btn-bg);
  }

  .ai-single-image-cta-btn--primary-{{ ai_gen_id }}:hover {
    transform: translateY(-1px);
  }

  .ai-single-image-cta-btn--primary-{{ ai_gen_id }}:hover svg {
    transform: translateX(2px);
  }

  .ai-single-image-cta-btn--secondary-{{ ai_gen_id }} {
    color: var(--mr-cta-ink);
    background-color: transparent;
    border: 1px solid color-mix(in srgb, var(--mr-cta-ink) 55%, transparent);
  }

  .ai-single-image-cta-btn--secondary-{{ ai_gen_id }}:hover {
    background-color: color-mix(in srgb, var(--mr-cta-ink) 6%, transparent);
    border-color: var(--mr-cta-ink);
  }

  .ai-single-image-cta-appstore-{{ ai_gen_id }} {
    display: none;
    margin: 2px 0 0;
    color: var(--mr-cta-ink);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.72;
  }

  .ai-single-image-cta-appstore-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-single-image-cta-btn-{{ ai_gen_id }}:focus-visible,
  .ai-single-image-cta-appstore-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid var(--mr-btn-bg);
    outline-offset: 3px;
  }

  @media screen and (max-width: 749px) {
    .ai-single-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-single-image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-single-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 1080 / 1350;
    }

    .ai-single-image-cta-{{ ai_gen_id }} {
      gap: 10px;
      padding: 14px 16px 16px;
    }

    .ai-single-image-cta-actions-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 8px;
    }

    .ai-single-image-cta-btn-{{ ai_gen_id }} {
      width: 100%;
      max-width: 360px;
    }

    .ai-single-image-cta-appstore-{{ ai_gen_id }} {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-single-image-cta-btn-{{ ai_gen_id }},
    .ai-single-image-cta-btn-{{ ai_gen_id }} svg {
      transition: none;
    }

    .ai-single-image-cta-btn--primary-{{ ai_gen_id }}:hover {
      transform: none;
    }

    .ai-single-image-cta-btn--primary-{{ ai_gen_id }}:hover svg {
      transform: none;
    }
  }
{% endstyle %}

<div class="ai-single-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-single-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 1920 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
        class="ai-single-image-desktop-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-single-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-single-image-empty-state-{{ ai_gen_id }}">
          Add a desktop image (1920 x 1080)
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1080 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="1080"
        height="1350"
        class="ai-single-image-mobile-{{ ai_gen_id }}"
      >
    {% elsif block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 1080 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="1080"
        height="1350"
        class="ai-single-image-mobile-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-single-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-single-image-empty-state-{{ ai_gen_id }}">
          Add a mobile image (1080 x 1350)
        </div>
      </div>
    {% endif %}
  </div>

  {%- if block.settings.button_label != blank or block.settings.secondary_label != blank or block.settings.app_store_link != blank -%}
    <div class="ai-single-image-cta-{{ ai_gen_id }}">
      {%- if block.settings.cta_support != blank -%}
        <p class="ai-single-image-cta-copy-{{ ai_gen_id }}">{{ block.settings.cta_support | escape }}</p>
      {%- endif -%}

      <div class="ai-single-image-cta-actions-{{ ai_gen_id }}">
        {%- if block.settings.button_label != blank -%}
          <a
            href="{{ block.settings.button_link | default: '/pages/shop-hats' }}"
            class="ai-single-image-cta-btn-{{ ai_gen_id }} ai-single-image-cta-btn--primary-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.button_label | escape }}</span>
            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if block.settings.secondary_label != blank -%}
          <a
            href="{{ block.settings.secondary_link | default: 'https://hatfinder.moonridgecompany.com' }}"
            class="ai-single-image-cta-btn-{{ ai_gen_id }} ai-single-image-cta-btn--secondary-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.secondary_label | escape }}</span>
          </a>
        {%- endif -%}
      </div>

      {%- if block.settings.app_store_link != blank and block.settings.app_store_label != blank -%}
        <a
          href="{{ block.settings.app_store_link }}"
          class="ai-single-image-cta-appstore-{{ ai_gen_id }}"
          target="_blank"
          rel="noopener"
        >
          {{ block.settings.app_store_label | escape }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Single image",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended size: 1920 x 1080 pixels"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended size: 1080 x 1350 pixels. If not set, desktop image will be used."
    },
    {
      "type": "header",
      "content": "Shop CTA"
    },
    {
      "type": "text",
      "id": "cta_support",
      "label": "Supporting line",
      "default": "Ready to find yours?"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop hats",
      "info": "Leave blank to hide the primary button."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Try Hat Finder"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link",
      "info": "Defaults to https://hatfinder.moonridgecompany.com if blank."
    },
    {
      "type": "text",
      "id": "app_store_label",
      "label": "App Store link label (mobile only)",
      "default": "Get the iPhone app",
      "info": "Only shows on mobile. Leave blank to hide."
    },
    {
      "type": "url",
      "id": "app_store_link",
      "label": "App Store link (mobile only)",
      "info": "Paste the App Store URL. Hidden on desktop."
    },
    {
      "type": "color",
      "id": "cta_background",
      "label": "CTA band background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Supporting text color",
      "default": "#312110"
    },
    {
      "type": "color",
      "id": "cta_accent_color",
      "label": "Top rule color",
      "default": "#c4b49a"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Primary button background",
      "default": "#312110"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Primary button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Single image"
    }
  ],
  "tag": null
}
{% endschema %}
