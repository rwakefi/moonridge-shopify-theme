{% style %}
  .events-directory {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
    font-family: var(--font-body-family);
  }
  .events-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .events-header h1 {
    font-family: var(--font-heading-family);
    font-size: 42px;
    font-weight: 700;
    margin: 0 0 16px 0;
    color: #111;
  }
  .events-header p {
    font-size: 18px;
    color: #555;
    max-width: 600px;
    margin: 0 auto;
  }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
  }
  .event-card {
    border: 1px solid #eaeaea;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .event-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }
  .event-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    background: #f5f5f5;
  }
  .event-card__content {
    padding: 24px;
  }
  .event-card__date {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    color: #C5A059;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }
  .event-card__title {
    font-family: var(--font-heading-family);
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 12px 0;
    color: #111;
  }
  .event-card__desc {
    font-size: 15px;
    color: #555;
    line-height: 1.5;
    margin: 0 0 20px 0;
  }
  .event-card__button {
    display: inline-block;
    padding: 10px 20px;
    background: #111;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s;
  }
  .event-card__button:hover {
    background: #333;
  }

  @media screen and (max-width: 768px) {
    .events-header h1 {
      font-size: 32px;
    }
  }
{% endstyle %}

<div class="events-directory">
  <div class="events-header">
    <h1>{{ section.settings.title }}</h1>
    <p>{{ section.settings.description }}</p>
  </div>

  <div class="events-grid">
    {% for block in section.blocks %}
      <div class="event-card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="event-card__image">
        {% else %}
          {{ 'collection-1' | placeholder_svg_tag: 'event-card__image' }}
        {% endif %}
        
        <div class="event-card__content">
          {% if block.settings.date != blank %}
            <div class="event-card__date">{{ block.settings.date }}</div>
          {% endif %}
          
          <h3 class="event-card__title">{{ block.settings.title }}</h3>
          
          {% if block.settings.description != blank %}
            <div class="event-card__desc">{{ block.settings.description }}</div>
          {% endif %}
          
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="event-card__button">{{ block.settings.button_text }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
    
    {% if section.blocks.size == 0 %}
      <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #777;">
        <p>No events currently scheduled. Add some blocks in the theme editor!</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Events Directory",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Upcoming Events"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Join us at Moon Ridge for our upcoming experiences, pop-ups, and community gatherings.</p>"
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Event Image"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date & Time",
          "default": "Oct 15, 2026 | 6:00 PM"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event Title",
          "default": "Hat Shaping Workshop"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Learn the art of custom hat shaping with our expert team.</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "RSVP Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Event Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Events Directory",
      "blocks": [
        {
          "type": "event"
        },
        {
          "type": "event"
        },
        {
          "type": "event"
        }
      ]
    }
  ]
}
{% endschema %}
