{% doc %}
  @prompt
    a section the same size as the lumen slideshow section below, this will just be a single picture, it needs to be 1920 by 1080, add a mobile image that is 1080 by 1350
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-single-image-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-single-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
  }

  .ai-single-image-desktop-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-single-image-mobile-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-single-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-single-image-cta-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding: 18px 20px 20px;
    background-color: {{ block.settings.cta_background | default: '#ffffff' }};
  }

  .ai-single-image-cta-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 28px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: {{ block.settings.button_text_color | default: '#ffffff' }};
    background-color: {{ block.settings.button_background | default: '#312110' }};
    border: 1px solid {{ block.settings.button_background | default: '#312110' }};
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .ai-single-image-cta-btn-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-single-image-cta-btn-{{ ai_gen_id }}:focus-visible {
    outline: 2px solid {{ block.settings.button_background | default: '#312110' }};
    outline-offset: 3px;
  }

  @media screen and (max-width: 749px) {
    .ai-single-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-single-image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-single-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 1080 / 1350;
    }

    .ai-single-image-cta-{{ ai_gen_id }} {
      padding: 16px 16px 18px;
    }

    .ai-single-image-cta-btn-{{ ai_gen_id }} {
      width: 100%;
      max-width: 360px;
    }
  }
{% endstyle %}

<div class="ai-single-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-single-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 1920 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
        class="ai-single-image-desktop-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-single-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-single-image-empty-state-{{ ai_gen_id }}">
          Add a desktop image (1920 x 1080)
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1080 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="1080"
        height="1350"
        class="ai-single-image-mobile-{{ ai_gen_id }}"
      >
    {% elsif block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 1080 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="1080"
        height="1350"
        class="ai-single-image-mobile-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-single-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-single-image-empty-state-{{ ai_gen_id }}">
          Add a mobile image (1080 x 1350)
        </div>
      </div>
    {% endif %}
  </div>

  {%- if block.settings.button_label != blank -%}
    <div class="ai-single-image-cta-{{ ai_gen_id }}">
      <a
        href="{{ block.settings.button_link | default: '/pages/shop-hats' }}"
        class="ai-single-image-cta-btn-{{ ai_gen_id }}"
      >
        {{ block.settings.button_label | escape }}
      </a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Single image",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended size: 1920 x 1080 pixels"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended size: 1080 x 1350 pixels. If not set, desktop image will be used."
    },
    {
      "type": "header",
      "content": "Shop CTA"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop hats",
      "info": "Leave blank to hide the button (easy rollback)."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#312110"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cta_background",
      "label": "CTA bar background",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Single image"
    }
  ],
  "tag": null
}
{% endschema %}
