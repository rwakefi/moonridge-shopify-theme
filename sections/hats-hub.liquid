{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .hats-hub-{{ section.id }} {
    --hats-hub-accent: {{ section.settings.accent_color }};
    --hats-hub-ink: #312110;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .hats-hub-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hats-hub-{{ section.id }} .hats-hub__inner {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hats-hub-ink);
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs li {
    display: inline-flex;
    align-items: center;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs li:not(:last-child)::after {
    content: '/';
    margin: 0 1.2rem;
    color: rgba(49, 33, 16, 0.35);
    font-weight: 300;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs a {
    color: var(--hats-hub-ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs a:hover {
    color: var(--hats-hub-accent);
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs [aria-current="page"] {
    color: rgba(49, 33, 16, 0.55);
  }

  .hats-hub-{{ section.id }} .hats-hub__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .hats-hub-{{ section.id }} .hats-hub__title {
    margin: 0 0 0.75rem;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--hats-hub-ink);
    font-weight: 500;
  }

  .hats-hub-{{ section.id }} .hats-hub__intro {
    margin: 0 auto;
    max-width: 42rem;
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(49, 33, 16, 0.8);
  }

  .hats-hub-{{ section.id }} .hats-hub__gender {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 3rem;
  }

  .hats-hub-{{ section.id }} .hats-hub__gender-btn {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border: 1px solid rgba(49, 33, 16, 0.25);
    background: transparent;
    color: var(--hats-hub-ink);
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__gender-btn:hover {
    border-color: var(--hats-hub-accent);
    color: var(--hats-hub-accent);
  }

  .hats-hub-{{ section.id }} .hats-hub__gender-btn.is-active {
    background: var(--hats-hub-ink);
    border-color: var(--hats-hub-ink);
    color: #fff;
  }

  .hats-hub-{{ section.id }} .hats-hub__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .hats-hub-{{ section.id }} .hats-hub__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.6rem;
    }
  }

  @media screen and (min-width: 990px) {
    .hats-hub-{{ section.id }} .hats-hub__grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  .hats-hub-{{ section.id }} .hats-hub__tile {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(49, 33, 16, 0.1);
    background: #faf8f5;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__tile:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(49, 33, 16, 0.12);
    border-color: var(--hats-hub-accent);
  }

  .hats-hub-{{ section.id }} .hats-hub__tile-media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #e8e2da;
  }

  .hats-hub-{{ section.id }} .hats-hub__tile-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__tile:hover .hats-hub__tile-media img {
    transform: scale(1.04);
  }

  .hats-hub-{{ section.id }} .hats-hub__tile-label {
    padding: 1.2rem 1rem;
    text-align: center;
    font-family: var(--font-heading-family);
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hats-hub-ink);
  }

  .hats-hub-{{ section.id }} .hats-hub__footer-link {
    display: block;
    text-align: center;
    margin-top: 3rem;
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hats-hub-accent);
    text-decoration: none;
    font-family: var(--font-heading-family);
  }

  .hats-hub-{{ section.id }} .hats-hub__footer-link:hover {
    text-decoration: underline;
  }
{%- endstyle -%}

<section class="hats-hub-{{ section.id }} gradient color-{{ section.settings.color_scheme }}" id="hats-hub-{{ section.id }}">
  <div class="hats-hub__inner page-width">
    <nav aria-label="Breadcrumb">
      <ol class="hats-hub__crumbs">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li><span aria-current="page">{{ section.settings.breadcrumb_label | default: 'Hats' | escape }}</span></li>
      </ol>
    </nav>

    <header class="hats-hub__header">
      {%- if section.settings.heading != blank -%}
        <h1 class="hats-hub__title">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="hats-hub__intro">{{ section.settings.intro | escape }}</p>
      {%- endif -%}
    </header>

    <div class="hats-hub__gender" role="group" aria-label="Shop by gender">
      <button type="button" class="hats-hub__gender-btn is-active" data-hats-gender="all" aria-pressed="true">
        {{ section.settings.label_all | default: 'All' | escape }}
      </button>
      <button type="button" class="hats-hub__gender-btn" data-hats-gender="men" aria-pressed="false">
        {{ section.settings.label_men | default: 'Men' | escape }}
      </button>
      <button type="button" class="hats-hub__gender-btn" data-hats-gender="women" aria-pressed="false">
        {{ section.settings.label_women | default: 'Women' | escape }}
      </button>
    </div>

    <ul class="hats-hub__grid" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign men_collection = block.settings.collection_men
          assign women_collection = block.settings.collection_women
          assign style_label = block.settings.title | downcase
          assign all_collection = nil

          if style_label contains 'western' or style_label contains 'cowboy'
            assign all_collection = collections['felt-hats']
          elsif style_label contains 'sun'
            assign all_collection = collections['straw-hats']
          elsif style_label contains 'fedora'
            assign all_collection = collections['fedoras']
          elsif style_label contains 'panama'
            assign all_collection = collections['panamas']
          elsif style_label contains 'ballcap'
            assign all_collection = collections['ballcaps-truckers-1']
          endif

          if block.settings.collection_all != blank and block.settings.collection_all.handle != blank
            assign all_collection = block.settings.collection_all
          endif

          assign image_mf_key = block.settings.image_metafield_key
          if image_mf_key == blank
            if style_label contains 'western' or style_label contains 'cowboy'
              assign image_mf_key = 'western'
            endif
          endif

          assign metafield_search = section.settings.metafield_search_collection
          if metafield_search == blank
            assign metafield_search = collections['hats-for-everyone']
          endif

          assign from_param = '?from=hats-hub'

          assign men_fallback = section.settings.men_fallback_collection
          assign women_fallback = section.settings.women_fallback_collection

          assign men_url = men_collection.url
          if men_url == blank and men_fallback != blank
            assign men_url = men_fallback.url
          endif

          assign women_url = women_collection.url
          if women_url == blank and women_fallback != blank
            assign women_url = women_fallback.url
          endif
        -%}
        <li {{ block.shopify_attributes }}>
          <a
            class="hats-hub__tile"
            data-hats-tile
            href="{% if all_collection %}{{ all_collection.url }}{{ from_param }}{% elsif men_url %}{{ men_url }}{{ from_param }}{% elsif women_url %}{{ women_url }}{{ from_param }}{% else %}#{% endif %}"
            data-url-all="{% if all_collection %}{{ all_collection.url }}{{ from_param }}{% endif %}"
            data-url-men="{% if men_url %}{{ men_url }}{{ from_param }}{% endif %}"
            data-url-women="{% if women_url %}{{ women_url }}{{ from_param }}{% endif %}"
          >
            <div class="hats-hub__tile-media">
              {%- render 'hats-hub-tile-media',
                block_image: block.settings.image,
                image_metafield_key: image_mf_key,
                collection_all: all_collection,
                collection_men: men_collection,
                collection_women: women_collection,
                metafield_search_collection: metafield_search,
                title: block.settings.title
              -%}
            </div>
            <span class="hats-hub__tile-label">{{ block.settings.title | escape }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- assign shop_all = section.settings.shop_all_collection -%}
    {%- if shop_all != blank -%}
        <a class="hats-hub__footer-link" href="{{ shop_all.url }}{{ from_param }}">
          {{ section.settings.shop_all_label | default: 'Shop all hats' | escape }} →
        </a>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('hats-hub-{{ section.id }}');
    if (!root) return;

    var storageKey = 'moonridgeHatsHubGender';
    var buttons = root.querySelectorAll('[data-hats-gender]');
    var tiles = root.querySelectorAll('[data-hats-tile]');

    function resolveUrl(tile, gender) {
      var url =
        gender === 'men'
          ? tile.getAttribute('data-url-men')
          : gender === 'women'
            ? tile.getAttribute('data-url-women')
            : tile.getAttribute('data-url-all');

      if (!url && gender === 'men') url = tile.getAttribute('data-url-all');
      if (!url && gender === 'women') url = tile.getAttribute('data-url-all');
      if (!url) url = tile.getAttribute('href');
      return url || tile.getAttribute('href');
    }

    function setGender(gender) {
      buttons.forEach(function (btn) {
        var active = btn.getAttribute('data-hats-gender') === gender;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      tiles.forEach(function (tile) {
        tile.setAttribute('href', resolveUrl(tile, gender));
      });

      try {
        sessionStorage.setItem(storageKey, gender);
      } catch (e) {}
    }

    var initial = 'all';
    try {
      initial = sessionStorage.getItem(storageKey) || 'all';
    } catch (e) {}

    if (initial !== 'men' && initial !== 'women') initial = 'all';
    setGender(initial);

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        setGender(btn.getAttribute('data-hats-gender'));
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Hats hub",
  "tag": "section",
  "class": "section-hats-hub",
  "settings": [
    {
      "type": "text",
      "id": "breadcrumb_label",
      "label": "Breadcrumb label",
      "default": "Hats"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop hats by style"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction",
      "default": "Choose a style below. Filter by men's or women's to find your fit faster."
    },
    {
      "type": "text",
      "id": "label_all",
      "label": "All toggle label",
      "default": "All"
    },
    {
      "type": "text",
      "id": "label_men",
      "label": "Men toggle label",
      "default": "Men"
    },
    {
      "type": "text",
      "id": "label_women",
      "label": "Women toggle label",
      "default": "Women"
    },
    {
      "type": "collection",
      "id": "metafield_search_collection",
      "label": "Catalog for metafield tile images",
      "info": "When a style tile uses a product metafield key, products are scanned here if not found in the tile's own collection(s). Use your main hats catalog (e.g. Hats For Everyone)."
    },
    {
      "type": "collection",
      "id": "shop_all_collection",
      "label": "Shop all collection"
    },
    {
      "type": "collection",
      "id": "men_fallback_collection",
      "label": "Men's fallback collection",
      "info": "Used when a style tile has no men's collection assigned."
    },
    {
      "type": "collection",
      "id": "women_fallback_collection",
      "label": "Women's fallback collection",
      "info": "Used when a style tile has no women's collection assigned."
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "Shop all link label",
      "default": "Shop all hats"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#C5A059"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "style_tile",
      "name": "Style tile",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Western hats"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)",
          "info": "Overrides automatic image. Leave empty to use product metafield or collection image."
        },
        {
          "type": "text",
          "id": "image_metafield_key",
          "label": "Product metafield key",
          "info": "Namespace is always custom. First product in the linked collection(s) with this metafield set to true is used (e.g. western for custom.western)."
        },
        {
          "type": "collection",
          "id": "collection_all",
          "label": "Collection (all / default)"
        },
        {
          "type": "collection",
          "id": "collection_men",
          "label": "Men's collection (optional)"
        },
        {
          "type": "collection",
          "id": "collection_women",
          "label": "Women's collection (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hats hub",
      "blocks": [
        {
          "type": "style_tile",
          "settings": {
            "title": "Western hats",
            "collection_all": "felt-hats",
            "image_metafield_key": "western"
          }
        },
        {
          "type": "style_tile",
          "settings": {
            "title": "Sun hats",
            "collection_all": "straw-hats"
          }
        },
        {
          "type": "style_tile",
          "settings": {
            "title": "Fedoras",
            "collection_all": "fedoras"
          }
        },
        {
          "type": "style_tile",
          "settings": {
            "title": "Panamas",
            "collection_all": "panamas"
          }
        },
        {
          "type": "style_tile",
          "settings": {
            "title": "Ballcaps",
            "collection_all": "ballcaps-truckers-1"
          }
        }
      ]
    }
  ]
}
{% endschema %}
