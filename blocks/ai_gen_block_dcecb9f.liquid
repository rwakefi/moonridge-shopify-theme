{% doc %}
  @prompt
    A google map bar and store hours, make the hors Monday-Friday and then Saturday and Sunday seperate, Hat Shapers in HouseThursday/Friday 10:00am - 5:00pmSaturday 10:00am- 2:00pmHours may vary based on private events, revert to the update before this didnt come through correctly, below the line below Sunday in this column I need a place to include 2 ones of text into a field, add one more line 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-map-hours-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ai-map-hours-container-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.map_width }}% {{ 100 | minus: block.settings.map_width }}%;
    }
  }

  .ai-map-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.map_height_mobile }}px;
    background-color: #f4f4f4;
  }

  @media screen and (min-width: 750px) {
    .ai-map-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.map_height }}px;
    }
  }

  .ai-map-wrapper-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .ai-map-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    color: #666;
    text-align: center;
    padding: 20px;
    font-size: 14px;
  }

  .ai-hours-wrapper-{{ ai_gen_id }} {
    padding: {{ block.settings.hours_padding_mobile }}px;
    background-color: {{ block.settings.hours_background_color }};
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .ai-hours-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.hours_padding }}px;
    }
  }

  .ai-hours-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    font-weight: 600;
  }

  .ai-hours-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-hours-item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    padding: {{ block.settings.item_spacing }}px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-hours-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-hours-day-{{ ai_gen_id }} {
    font-weight: 600;
  }

  .ai-hours-time-{{ ai_gen_id }} {
    text-align: right;
  }

  .ai-additional-info-{{ ai_gen_id }} {
    margin-top: {{ block.settings.additional_info_spacing }}px;
    padding-top: {{ block.settings.additional_info_spacing }}px;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-additional-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    margin: 0 0 8px 0;
  }

  .ai-additional-text-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-address-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.address_spacing }}px;
    padding-top: {{ block.settings.address_spacing }}px;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-address-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px 0;
    font-weight: 600;
  }

  .ai-address-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-contact-info-{{ ai_gen_id }} {
    margin-top: 12px;
  }

  .ai-contact-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    display: block;
    margin-top: 4px;
  }

  .ai-contact-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }
{% endstyle %}

<div
  class="ai-map-hours-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-map-wrapper-{{ ai_gen_id }}">
    {% if block.settings.google_maps_embed != blank %}
      {{ block.settings.google_maps_embed }}
    {% else %}
      <div class="ai-map-placeholder-{{ ai_gen_id }}">
        Next, add your Google Maps embed code
      </div>
    {% endif %}
  </div>

  <div class="ai-hours-wrapper-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h3 class="ai-hours-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    {% endif %}

    <ul class="ai-hours-list-{{ ai_gen_id }}">
      {% if block.settings.weekday_hours != blank %}
        <li class="ai-hours-item-{{ ai_gen_id }}">
          <span class="ai-hours-day-{{ ai_gen_id }}">Monday - Friday</span>
          <span class="ai-hours-time-{{ ai_gen_id }}">{{ block.settings.weekday_hours }}</span>
        </li>
      {% endif %}

      {% if block.settings.saturday_hours != blank %}
        <li class="ai-hours-item-{{ ai_gen_id }}">
          <span class="ai-hours-day-{{ ai_gen_id }}">Saturday</span>
          <span class="ai-hours-time-{{ ai_gen_id }}">{{ block.settings.saturday_hours }}</span>
        </li>
      {% endif %}

      {% if block.settings.sunday_hours != blank %}
        <li class="ai-hours-item-{{ ai_gen_id }}">
          <span class="ai-hours-day-{{ ai_gen_id }}">Sunday</span>
          <span class="ai-hours-time-{{ ai_gen_id }}">{{ block.settings.sunday_hours }}</span>
        </li>
      {% endif %}
    </ul>

    {% if block.settings.additional_text_1 != blank or block.settings.additional_text_2 != blank or block.settings.additional_text_3 != blank %}
      <div class="ai-additional-info-{{ ai_gen_id }}">
        {% if block.settings.additional_text_1 != blank %}
          <p class="ai-additional-text-{{ ai_gen_id }}">{{ block.settings.additional_text_1 }}</p>
        {% endif %}

        {% if block.settings.additional_text_2 != blank %}
          <p class="ai-additional-text-{{ ai_gen_id }}">{{ block.settings.additional_text_2 }}</p>
        {% endif %}

        {% if block.settings.additional_text_3 != blank %}
          <p class="ai-additional-text-{{ ai_gen_id }}">{{ block.settings.additional_text_3 }}</p>
        {% endif %}

        {% if block.settings.additional_text_4 != blank %}
          <p class="ai-additional-text-{{ ai_gen_id }}">{{ block.settings.additional_text_4 }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_address %}
      <div class="ai-address-wrapper-{{ ai_gen_id }}">
        {% if block.settings.address_heading != blank %}
          <h4 class="ai-address-heading-{{ ai_gen_id }}">{{ block.settings.address_heading }}</h4>
        {% endif %}

        {% if block.settings.address != blank %}
          <p class="ai-address-text-{{ ai_gen_id }}">{{ block.settings.address }}</p>
        {% endif %}

        {% if block.settings.show_contact_info %}
          <div class="ai-contact-info-{{ ai_gen_id }}">
            {% if block.settings.phone != blank %}
              <a href="tel:{{ block.settings.phone }}" class="ai-contact-link-{{ ai_gen_id }}">
                {{ block.settings.phone }}
              </a>
            {% endif %}

            {% if block.settings.email != blank %}
              <a href="mailto:{{ block.settings.email }}" class="ai-contact-link-{{ ai_gen_id }}">
                {{ block.settings.email }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

