<style>
/* Lucchese Experience Landing Page - J.Crew Inspired Aesthetic */

.section-lucchese-experience {
  background-color: #ffffff;
  color: #2c2c2c;
  font-family: var(--font-body-family);
  font-style: var(--font-body-style);
  font-weight: var(--font-body-weight);
  margin: 0;
  padding: 0;
}

/* Typography Overrides */
.lucchese-exp h1,
.lucchese-exp h2,
.lucchese-exp h3 {
  font-family: var(--font-heading-family);
  font-style: var(--font-heading-style);
  font-weight: var(--font-heading-weight, normal);
  letter-spacing: 0.05em;
  color: #1a1a1a;
  text-transform: uppercase;
  margin: 0;
}

/* 1. Header Bar (J.Crew style) */
.lucchese-exp__header-bar {
  position: relative;
  text-align: center;
  padding: 10rem 0;
  border-bottom: 1px solid #eaeaea;
  background-image: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url({{ 'lucchese-header-bg.jpg' | asset_url }});
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  
  /* Full-bleed width breakout to cover screen edges */
  width: 100vw;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
}

@media screen and (min-width: 750px) {
  .lucchese-exp__header-bar {
    padding: 16rem 0;
  }
}

.lucchese-exp__header-eyebrow {
  display: block;
  font-family: var(--font-heading-family);
  font-style: var(--font-heading-style);
  font-size: 2rem;
  letter-spacing: 0.25em;
  color: rgba(255, 255, 255, 0.95);
  text-transform: uppercase;
  margin-bottom: 1.2rem;
  font-weight: 600;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
}

.lucchese-exp__header-title {
  font-size: calc(var(--font-heading-scale) * 3rem) !important;
  line-height: 1.2;
  color: #ffffff !important;
  text-shadow: 0 2px 5px rgba(0, 0, 0, 0.7);
}

@media only screen and (min-width: 750px) {
  .lucchese-exp__header-title {
    font-size: calc(var(--font-heading-scale) * 4rem) !important;
  }
}

/* 2. Narrative & Image Split Layout */
.lucchese-exp__split {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4rem;
  padding-top: 5rem;
  padding-bottom: 5rem;
  align-items: center;
}

@media screen and (min-width: 990px) {
  .lucchese-exp__split {
    grid-template-columns: 1.1fr 0.9fr;
    gap: 8rem;
    padding-top: 8rem;
    padding-bottom: 8rem;
  }
}

.lucchese-exp__split-heading {
  font-size: calc(var(--font-heading-scale) * 2rem) !important;
  margin-bottom: 2.5rem !important;
  line-height: 1.2;
}

@media only screen and (min-width: 750px) {
  .lucchese-exp__split-heading {
    font-size: calc(var(--font-heading-scale) * 2.4rem) !important;
  }
}

.lucchese-exp__split-text p {
  font-size: 1.6rem;
  line-height: 1.7;
  color: #4a4a4a;
  margin: 0 0 3rem 0;
}

/* Split Meta Rows */
.lucchese-exp__split-meta {
  border-top: 1px solid #eaeaea;
  border-bottom: 1px solid #eaeaea;
  padding: 2.5rem 0;
  margin-bottom: 4rem;
}

.lucchese-exp__meta-row {
  display: flex;
  margin-bottom: 1.5rem;
  font-size: 1.4rem;
  line-height: 1.5;
}

.lucchese-exp__meta-row:last-child {
  margin-bottom: 0;
}

.lucchese-exp__meta-label {
  font-weight: bold;
  text-transform: uppercase;
  color: #1a1a1a;
  width: 100px;
  flex-shrink: 0;
  letter-spacing: 0.05em;
}

.lucchese-exp__meta-value {
  color: #555555;
}

/* Action Area with Logos */
.lucchese-exp__action-badge {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 3rem;
}

.lucchese-exp__action-logos {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.lucchese-exp__m-logo-small {
  height: 36px;
  width: auto;
  opacity: 0.85;
}

.lucchese-exp__action-divider {
  font-size: 1.8rem;
  color: #999999;
}

.lucchese-exp__lucchese-logo-small {
  height: 24px;
  width: auto;
  opacity: 0.85;
}

.lucchese-exp__cta-btn {
  text-transform: uppercase;
  letter-spacing: 0.15em;
  padding: 1.4rem 3rem;
  font-size: 1.2rem;
  font-weight: bold;
  border: 1px solid #1a1a1a;
  background-color: transparent;
  color: #1a1a1a;
  cursor: pointer;
  transition: all 0.2s ease;
  text-decoration: none;
}

.lucchese-exp__cta-btn:hover {
  background-color: #1a1a1a;
  color: #ffffff;
}

/* Image Column Styling */
.lucchese-exp__split-media {
  width: 100%;
}

.lucchese-exp__media-wrapper {
  overflow: hidden;
  background-color: #f7f7f7;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
}

.lucchese-exp__main-img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

.placeholder-wrapper {
  aspect-ratio: 4 / 3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-wrapper svg {
  width: 100px;
  height: 100px;
  fill: #cccccc;
}

/* 3. Booking Section (Light Form Sheet) */
.lucchese-exp__booking {
  border-top: 1px solid #eaeaea;
  padding-top: 6rem;
  padding-bottom: 8rem;
}

.lucchese-exp__booking-container {
  max-width: 750px;
  margin: 0 auto;
}

.lucchese-exp__booking-header {
  text-align: center;
  margin-bottom: 4rem;
}

.lucchese-exp__booking-header h2 {
  font-size: calc(var(--font-heading-scale) * 2rem);
  margin-bottom: 1.5rem;
  letter-spacing: 0.1em;
}

.lucchese-exp__booking-header p {
  font-size: 1.5rem;
  line-height: 1.6;
  color: #666666;
}

/* Form Styles */
.lucchese-exp__form-wrapper {
  background-color: #faf8f5;
  padding: 4rem 3rem;
  border: 1px solid #eaeaea;
}

@media screen and (min-width: 750px) {
  .lucchese-exp__form-wrapper {
    padding: 6rem 5rem;
  }
}

.lucchese-exp__form-fields {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.lucchese-exp__input-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
}

@media screen and (min-width: 600px) {
  .lucchese-exp__input-row {
    grid-template-columns: 1fr 1fr;
  }
}

/* Clean Input Groups (Label Above Input - NO Overlapping) */
.lucchese-exp__input-group {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  text-align: left;
}

.lucchese-exp__input-group label {
  font-size: 1.1rem;
  font-weight: bold;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #1a1a1a;
}

.lucchese-exp__input-group input[type="text"],
.lucchese-exp__input-group input[type="email"],
.lucchese-exp__input-group input[type="tel"],
.lucchese-exp__input-group input[type="date"],
.lucchese-exp__input-group select,
.lucchese-exp__input-group textarea {
  width: 100%;
  font-family: inherit;
  font-size: 1.4rem;
  color: #2c2c2c;
  padding: 1.2rem 1.5rem;
  border: 1px solid #cccccc;
  background-color: #ffffff;
  outline: none;
  border-radius: 0; /* J.Crew style sharp corners */
  transition: border-color 0.2s ease;
}

.lucchese-exp__input-group input:focus,
.lucchese-exp__input-group select:focus,
.lucchese-exp__input-group textarea:focus {
  border-color: #1a1a1a;
}

/* Date input specific formatting */
.lucchese-exp__input-group input[type="date"] {
  min-height: 4.5rem;
}

/* Select wrapper styling */
.lucchese-exp__select-wrapper {
  position: relative;
  width: 100%;
}

.lucchese-exp__select-wrapper select {
  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;
  padding-right: 4rem !important;
}

.lucchese-exp__select-wrapper::after {
  content: '';
  position: absolute;
  right: 1.8rem;
  top: 50%;
  transform: translateY(-50%) rotate(45deg);
  width: 6px;
  height: 6px;
  border-right: 1.5px solid #1a1a1a;
  border-bottom: 1.5px solid #1a1a1a;
  pointer-events: none;
}

/* Textarea styling */
.lucchese-exp__input-group textarea {
  min-height: 10rem;
  resize: vertical;
}

/* Form Actions Button */
.lucchese-exp__submit-btn {
  width: 100%;
  padding: 1.6rem 3rem;
  font-size: 1.3rem;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  background-color: #1a1a1a;
  color: #ffffff;
  border: 1px solid #1a1a1a;
  cursor: pointer;
  transition: all 0.2s ease;
  margin-top: 1rem;
}

.lucchese-exp__submit-btn:hover {
  background-color: transparent;
  color: #1a1a1a;
}

/* Success & Error Messaging */
.lucchese-exp__form-success {
  background-color: #f4f8f2;
  color: #2b5c1a;
  border: 1px solid #dcebd6;
  padding: 1.5rem 2rem;
  font-size: 1.4rem;
  display: flex;
  align-items: center;
  gap: 1.2rem;
  text-align: left;
}

.lucchese-exp__form-errors {
  background-color: #fff5f5;
  color: #b52a2a;
  border: 1px solid #ffd6d6;
  padding: 1.5rem 2rem;
  font-size: 1.4rem;
  text-align: left;
}

.lucchese-exp__form-errors p {
  margin: 0 0 1rem 0;
  font-weight: bold;
}

.lucchese-exp__form-errors ul {
  margin: 0;
  padding-left: 2rem;
}

/* 4. Video Gallery Section */
.lucchese-exp__videos {
  padding-top: 5rem;
  padding-bottom: 5rem;
  border-top: 1px solid #eaeaea;
}

.lucchese-exp__videos-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
}

@media screen and (min-width: 750px) {
  .lucchese-exp__videos-grid {
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
}

.lucchese-exp__video-wrapper {
  background-color: #faf8f5;
  border: 1px solid #eaeaea;
  padding: 1.2rem;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.lucchese-exp__video-wrapper:hover {
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
}

.lucchese-exp__video-aspect {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
  overflow: hidden;
}

.lucchese-exp__video-aspect iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 0;
}
</style>

<section class="lucchese-exp section-{{ section.id }}-padding" id="LuccheseExp-{{ section.id }}">
  
  <!-- 1. Header Banner (J.Crew style centered title bar) -->
  <div class="lucchese-exp__header-bar">
    <div class="page-width">
      <span class="lucchese-exp__header-eyebrow">{{ section.settings.eyebrow | default: "EXCLUSIVE SERVICES" | escape }}</span>
      <h1 class="lucchese-exp__header-title">{{ section.settings.heading | default: "PRIVATE APPOINTMENTS" | escape }}</h1>
    </div>
  </div>

  <!-- 2. Main Narrative & Image Split Layout -->
  <div class="lucchese-exp__split page-width">
    
    <!-- Left: Content & Narrative -->
    <div class="lucchese-exp__split-content">
      <h2 class="lucchese-exp__split-heading">{{ section.settings.narrative_title | default: "Lucchese Private Fitting" | escape }}</h2>
      
      <div class="lucchese-exp__split-text">
        {{ section.settings.narrative_text | default: "<p>Experience the ultimate in personal service. Book an exclusive, after-hours fitting session in our showroom. Browse and try on our ready-to-wear Lucchese collection with a dedicated boot specialist—entirely to yourself.</p>" }}
      </div>

      <div class="lucchese-exp__split-meta">
        <div class="lucchese-exp__meta-row">
          <span class="lucchese-exp__meta-label">Duration:</span>
          <span class="lucchese-exp__meta-value">30 Minutes (Exclusive After-Hours Session)</span>
        </div>
        <div class="lucchese-exp__meta-row">
          <span class="lucchese-exp__meta-label">Access:</span>
          <span class="lucchese-exp__meta-value">Private Showroom, Dedicated Fitting Specialist</span>
        </div>
        <div class="lucchese-exp__meta-row">
          <span class="lucchese-exp__meta-label">Fee:</span>
          <span class="lucchese-exp__meta-value">Complimentary (Reservation Required)</span>
        </div>
      </div>

      <!-- Action Area with Logo Badges -->
      <div class="lucchese-exp__action-badge">
        <div class="lucchese-exp__action-logos">
          {%- if section.settings.logo_moonridge_m != blank -%}
            <img src="{{ section.settings.logo_moonridge_m | image_url: width: 80 }}" alt="Moon Ridge M" class="lucchese-exp__m-logo-small">
          {%- endif -%}
          <span class="lucchese-exp__action-divider">&times;</span>
          {%- if section.settings.logo_lucchese != blank -%}
            <img src="{{ section.settings.logo_lucchese | image_url: width: 160 }}" alt="Lucchese" class="lucchese-exp__lucchese-logo-small">
          {%- endif -%}
        </div>
        <a href="#booking-form" class="button button--secondary lucchese-exp__cta-btn">
          Request an Appointment
        </a>
      </div>
    </div>

    <!-- Right: High Quality Showcase Image -->
    <div class="lucchese-exp__split-media">
      {%- if section.settings.hero_image != blank -%}
        <div class="lucchese-exp__media-wrapper">
          <img src="{{ section.settings.hero_image | image_url: width: 1200 }}" alt="Lucchese private fitting experience" class="lucchese-exp__main-img" loading="lazy">
        </div>
      {%- else -%}
        <div class="lucchese-exp__media-wrapper">
          <img src="{{ 'lucchese-showcase.jpg' | asset_url }}" alt="Lucchese private fitting experience" class="lucchese-exp__main-img" loading="lazy">
        </div>
      {%- endif -%}
    </div>
  </div>

  <!-- 4. Video Gallery Section -->
  <div class="lucchese-exp__videos page-width">
    <div class="lucchese-exp__videos-grid">
      <div class="lucchese-exp__video-wrapper">
        <div class="lucchese-exp__video-aspect">
          <iframe src="https://lucchese.widen.net/view/video/oqjroy2ruu/Lucchese_Film_FINAL.mp4.crdownload?x.portal_shortcode_generated=zn091gk5&x.app=portals" webkitallowfullscreen mozallowfullscreen allowfullscreen frameborder="0" allowtransparency="true" scrolling="no"></iframe>
        </div>
      </div>
      <div class="lucchese-exp__video-wrapper">
        <div class="lucchese-exp__video-aspect">
          <iframe src="https://lucchese.widen.net/view/video/pzwxjftlmu/Lucchese_60sec_FINAL.mp4.crdownload?x.portal_shortcode_generated=zn091gk5&x.app=portals" webkitallowfullscreen mozallowfullscreen allowfullscreen frameborder="0" allowtransparency="true" scrolling="no"></iframe>
        </div>
      </div>
    </div>
  </div>

  <!-- 3. Form Section (Centered, Clean Reservation Sheet) -->
  <div class="lucchese-exp__booking page-width" id="booking-form">
    <div class="lucchese-exp__booking-container">
      <div class="lucchese-exp__booking-header">
        <h2>FITTING RESERVATION</h2>
        <p>Please share your preferences below, and our team will contact you within 24 hours to coordinate your after-hours fitting.</p>
      </div>

      <div class="lucchese-exp__form-wrapper">
        {%- form 'contact', id: 'LuccheseBookingForm', class: 'lucchese-exp__form' -%}
          {%- if form.posted_successfully? -%}
            <div class="lucchese-exp__form-success" tabindex="-1" autofocus>
              <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20">
                <path fill="currentColor" d="M10 0C4.48 0 0 4.48 0 10s4.48 10 10 10 10-4.48 10-10S15.52 0 10 0zm-2 15l-5-5 1.41-1.41L8 12.17l7.59-7.59L17 6l-9 9z"/>
              </svg>
              <span>{{ section.settings.success_message | default: 'Thank you! Your private booking request has been received. Our team will contact you shortly.' }}</span>
            </div>
          {%- elsif form.errors -%}
            <div class="lucchese-exp__form-errors">
              <p class="form__message" role="alert" tabindex="-1" autofocus>
                Please correct the errors below.
              </p>
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="lucchese-exp__form-fields">
            <input type="hidden" name="contact[Booking Type]" value="Lucchese Boot Private Fitting Experience">

            <div class="lucchese-exp__input-group">
              <label for="LuccheseForm-name">Full Name *</label>
              <input type="text" id="LuccheseForm-name" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="e.g. Sarah Jenkins" required>
            </div>

            <div class="lucchese-exp__input-row">
              <div class="lucchese-exp__input-group">
                <label for="LuccheseForm-email">Email Address *</label>
                <input type="email" id="LuccheseForm-email" name="contact[email]" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="e.g. sarah@example.com" required>
              </div>

              <div class="lucchese-exp__input-group">
                <label for="LuccheseForm-phone">Phone Number *</label>
                <input type="tel" id="LuccheseForm-phone" name="contact[phone]" pattern="[0-9\- \+\(\)]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" placeholder="e.g. (479) 555-0199" required>
              </div>
            </div>

            <div class="lucchese-exp__input-row">
              <div class="lucchese-exp__input-group">
                <label for="LuccheseForm-date">Preferred Date *</label>
                <input type="date" id="LuccheseForm-date" name="contact[Preferred Date]" required min="{{ "now" | date: "%Y-%m-%d" }}">
              </div>

              <div class="lucchese-exp__input-group">
                <label for="LuccheseForm-time">Preferred Time Slot *</label>
                <div class="lucchese-exp__select-wrapper">
                  <select id="LuccheseForm-time" name="contact[Preferred Time]" required>
                    <option value="" disabled selected>Select Time Slot</option>
                    <option value="After-Hours Morning (8:00 AM - 10:00 AM)">After-Hours Morning (8:00 AM - 10:00 AM)</option>
                    <option value="After-Hours Evening (5:00 PM - 7:00 PM)">After-Hours Evening (5:00 PM - 7:00 PM)</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="lucchese-exp__input-row">
              <div class="lucchese-exp__input-group">
                <label for="LuccheseForm-size">Estimated Boot Size *</label>
                <input type="text" id="LuccheseForm-size" name="contact[Estimated Boot Size]" placeholder="e.g. Mens 10.5 D, Womens 8 B" required>
              </div>

              <div class="lucchese-exp__input-group">
                <label for="LuccheseForm-style">Style/Leather Preference</label>
                <div class="lucchese-exp__select-wrapper">
                  <select id="LuccheseForm-style" name="contact[Style Interest]">
                    <option value="" disabled selected>Select Style Interest</option>
                    <option value="Exotic Skins (Caiman / Alligator)">Exotic Skins (Caiman / Alligator)</option>
                    <option value="Ostrich / Lizard">Ostrich / Lizard</option>
                    <option value="Classic Smooth Leather / Calfskin">Classic Smooth Leather / Calfskin</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="lucchese-exp__input-group">
              <label for="LuccheseForm-notes">Special Requests or Fitting Notes</label>
              <textarea rows="3" id="LuccheseForm-notes" name="contact[Custom Fitting Notes]" placeholder="Tell us if you are looking for a specific model, or have special width requirements..."></textarea>
            </div>

            <div class="lucchese-exp__form-actions">
              <button type="submit" class="button button--primary lucchese-exp__submit-btn">
                Request Fitting Reservation
              </button>
            </div>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lucchese Private Fitting",
  "tag": "section",
  "class": "section-lucchese-experience",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Showcase Image"
    },
    {
      "type": "image_picker",
      "id": "logo_moonridge_m",
      "label": "Moon Ridge Logo (M)"
    },
    {
      "type": "image_picker",
      "id": "logo_lucchese",
      "label": "Lucchese Logo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Header Eyebrow",
      "default": "Moon Ridge"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Header Title",
      "default": "LUCCHESE EXPERIENCE"
    },
    {
      "type": "text",
      "id": "narrative_title",
      "label": "Narrative Title",
      "default": "Lucchese Private Fitting"
    },
    {
      "type": "richtext",
      "id": "narrative_text",
      "label": "Narrative Description",
      "default": "<p>Experience the ultimate in personal service. Book an exclusive, after-hours fitting session in our showroom. Browse and try on our ready-to-wear Lucchese collection with a dedicated boot specialist—entirely to yourself.</p>"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Form Success Message",
      "default": "Thank you! Your private booking request has been received. Our team will contact you shortly to finalize your date."
    }
  ],
  "presets": [
    {
      "name": "Lucchese Private Fitting"
    }
