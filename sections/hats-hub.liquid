{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }},
  .hats-hub-{{ section.id }} {
    --hats-hub-accent: {{ section.settings.accent_color }};
    --hats-hub-ink: #312110;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  .hats-hub-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .hats-hub-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .hats-hub-{{ section.id }} .hats-hub__inner {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hats-hub-ink);
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs li {
    display: inline-flex;
    align-items: center;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs li:not(:last-child)::after {
    content: '/';
    margin: 0 1.2rem;
    color: rgba(49, 33, 16, 0.35);
    font-weight: 300;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs a {
    color: var(--hats-hub-ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs a:hover {
    color: var(--hats-hub-accent);
  }

  .hats-hub-{{ section.id }} .hats-hub__crumbs [aria-current="page"] {
    color: rgba(49, 33, 16, 0.55);
  }

  .hats-hub-{{ section.id }} .hats-hub__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .hats-hub-{{ section.id }} .hats-hub__title {
    margin: 0 0 0.75rem;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--hats-hub-ink);
    font-weight: 500;
  }

  .hats-hub-{{ section.id }} .hats-hub__intro {
    margin: 0 auto;
    max-width: 42rem;
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(49, 33, 16, 0.8);
  }

  .hats-hub-{{ section.id }} .hats-hub__gender {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 3rem;
  }

  .hats-hub-{{ section.id }} .hats-hub__gender-btn {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.9rem 2rem;
    border: 1px solid rgba(49, 33, 16, 0.25);
    background: transparent;
    color: var(--hats-hub-ink);
    cursor: pointer;
    border-radius: 2px;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__gender-btn:hover {
    border-color: var(--hats-hub-accent);
    color: var(--hats-hub-accent);
  }

  .hats-hub-{{ section.id }} .hats-hub__gender-btn.is-active {
    background: var(--hats-hub-ink);
    border-color: var(--hats-hub-ink);
    color: #fff;
  }

  .hats-hub-{{ section.id }} .hats-hub__row {
    margin-bottom: 3.5rem;
  }

  .hats-hub-{{ section.id }} .hats-hub__row:last-of-type {
    margin-bottom: 0;
  }

  .hats-hub-{{ section.id }} .hats-hub__row-title {
    margin: 0 0 1.6rem;
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hats-hub-ink);
    font-weight: 500;
    font-family: var(--font-heading-family);
  }

  .hats-hub-{{ section.id }} .hats-hub__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .hats-hub-{{ section.id }} .hats-hub__grid {
      gap: 1.6rem;
    }

    .hats-hub-{{ section.id }} .hats-hub__grid--hat-type {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .hats-hub-{{ section.id }} .hats-hub__grid--style {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .hats-hub-{{ section.id }} .hats-hub__tile {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(49, 33, 16, 0.1);
    background: transparent;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__tile:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(49, 33, 16, 0.12);
    border-color: var(--hats-hub-accent);
  }

  .hats-hub-{{ section.id }} .hats-hub__tile-media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: transparent;
  }

  .hats-hub-{{ section.id }} .hats-hub__tile-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .hats-hub-{{ section.id }} .hats-hub__tile:hover .hats-hub__tile-media img {
    transform: scale(1.04);
  }

  .hats-hub-{{ section.id }} .hats-hub__tile-label {
    padding: 1.2rem 1rem;
    text-align: center;
    font-family: var(--font-heading-family);
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hats-hub-ink);
  }

  .hats-hub-{{ section.id }} .hats-hub__footer-link {
    display: block;
    text-align: center;
    margin-top: 3rem;
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hats-hub-accent);
    text-decoration: none;
    font-family: var(--font-heading-family);
  }

  .hats-hub-{{ section.id }} .hats-hub__footer-link:hover {
    text-decoration: underline;
  }
{%- endstyle -%}

<section class="hats-hub-{{ section.id }}" id="hats-hub-{{ section.id }}">
  <div class="hats-hub__inner page-width">
    <nav aria-label="Breadcrumb">
      <ol class="hats-hub__crumbs">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li><span aria-current="page">{{ section.settings.breadcrumb_label | default: 'Hats' | escape }}</span></li>
      </ol>
    </nav>

    <header class="hats-hub__header">
      {%- if section.settings.heading != blank -%}
        <h1 class="hats-hub__title">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="hats-hub__intro">{{ section.settings.intro | escape }}</p>
      {%- endif -%}
    </header>

    <div class="hats-hub__gender" role="group" aria-label="Shop by gender">
      <button type="button" class="hats-hub__gender-btn is-active" data-hats-gender="all" aria-pressed="true">
        {{ section.settings.label_all | default: 'All' | escape }}
      </button>
      <button type="button" class="hats-hub__gender-btn" data-hats-gender="men" aria-pressed="false">
        {{ section.settings.label_men | default: 'Men' | escape }}
      </button>
      <button type="button" class="hats-hub__gender-btn" data-hats-gender="women" aria-pressed="false">
        {{ section.settings.label_women | default: 'Women' | escape }}
      </button>
    </div>

    {%- assign from_param = '?from=hats-hub' -%}

    {%- if section.settings.row_hat_type_heading != blank -%}
      <div class="hats-hub__row">
        <h2 class="hats-hub__row-title">{{ section.settings.row_hat_type_heading | escape }}</h2>
        <ul class="hats-hub__grid hats-hub__grid--hat-type" role="list">
          {%- for block in section.blocks -%}
            {%- if block.settings.row == 'hat_type' -%}
              {%- render 'hats-hub-tile', block: block, section: section, from_param: from_param -%}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if section.settings.row_style_heading != blank -%}
      <div class="hats-hub__row">
        <h2 class="hats-hub__row-title">{{ section.settings.row_style_heading | escape }}</h2>
        <ul class="hats-hub__grid hats-hub__grid--style" role="list">
          {%- for block in section.blocks -%}
            {%- if block.settings.row == 'style' -%}
              {%- render 'hats-hub-tile', block: block, section: section, from_param: from_param -%}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- assign shop_all = section.settings.shop_all_collection -%}
    {%- if shop_all != blank -%}
        <a class="hats-hub__footer-link" href="{{ shop_all.url }}{{ from_param }}">
          {{ section.settings.shop_all_label | default: 'Shop all hats' | escape }} →
        </a>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('hats-hub-{{ section.id }}');
    if (!root) return;

    var storageKey = 'moonridgeHatsHubGender';
    var buttons = root.querySelectorAll('[data-hats-gender]');
    var tiles = root.querySelectorAll('[data-hats-tile]');

    function resolveUrl(tile, gender) {
      var url =
        gender === 'men'
          ? tile.getAttribute('data-url-men')
          : gender === 'women'
            ? tile.getAttribute('data-url-women')
            : tile.getAttribute('data-url-all');

      if (!url && gender === 'men') url = tile.getAttribute('data-url-all');
      if (!url && gender === 'women') url = tile.getAttribute('data-url-all');
      if (!url) url = tile.getAttribute('href');
      return url || tile.getAttribute('href');
    }

    function setGender(gender) {
      buttons.forEach(function (btn) {
        var active = btn.getAttribute('data-hats-gender') === gender;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      tiles.forEach(function (tile) {
        tile.setAttribute('href', resolveUrl(tile, gender));
      });

      try {
        sessionStorage.setItem(storageKey, gender);
      } catch (e) {}
    }

    var initial = 'all';
    try {
      initial = sessionStorage.getItem(storageKey) || 'all';
    } catch (e) {}

    if (initial !== 'men' && initial !== 'women') initial = 'all';
    setGender(initial);

    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        setGender(btn.getAttribute('data-hats-gender'));
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Hats hub",
  "tag": "section",
  "class": "section-hats-hub",
  "settings": [
    {
      "type": "text",
      "id": "breadcrumb_label",
      "label": "Breadcrumb label",
      "default": "Hats"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop hats"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction",
      "default": "Browse by hat type or style. Filter by men's or women's to find your fit faster."
    },
    {
      "type": "text",
      "id": "row_hat_type_heading",
      "label": "Hat type row heading",
      "default": "Hat type"
    },
    {
      "type": "text",
      "id": "row_style_heading",
      "label": "Style row heading",
      "default": "Style"
    },
    {
      "type": "text",
      "id": "label_all",
      "label": "All toggle label",
      "default": "All"
    },
    {
      "type": "text",
      "id": "label_men",
      "label": "Men toggle label",
      "default": "Men"
    },
    {
      "type": "text",
      "id": "label_women",
      "label": "Women toggle label",
      "default": "Women"
    },
    {
      "type": "collection",
      "id": "metafield_search_collection",
      "label": "Catalog for metafield tile images",
      "info": "When a style tile uses a product metafield key, products are scanned here if not found in the tile's own collection(s). Use your main hats catalog (e.g. Hats For Everyone)."
    },
    {
      "type": "collection",
      "id": "shop_all_collection",
      "label": "Shop all collection"
    },
    {
      "type": "collection",
      "id": "men_fallback_collection",
      "label": "Men's fallback collection",
      "info": "Used when a style tile has no men's collection assigned."
    },
    {
      "type": "collection",
      "id": "women_fallback_collection",
      "label": "Women's fallback collection",
      "info": "Used when a style tile has no women's collection assigned."
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "Shop all link label",
      "default": "Shop all hats"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#C5A059"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "hub_tile",
      "name": "Hub tile",
      "settings": [
        {
          "type": "select",
          "id": "row",
          "label": "Row",
          "options": [
            { "value": "hat_type", "label": "Hat type" },
            { "value": "style", "label": "Style" }
          ],
          "default": "hat_type"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Felt"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle",
          "info": "e.g. felt-hats, western-hats. Used when no collection is picked below."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)",
          "info": "1200×1200 recommended. Overrides collection / metafield image."
        },
        {
          "type": "text",
          "id": "image_metafield_key",
          "label": "Product metafield key",
          "info": "Optional. Namespace custom. e.g. western for custom.western."
        },
        {
          "type": "collection",
          "id": "collection_all",
          "label": "Collection (all / default)"
        },
        {
          "type": "collection",
          "id": "collection_men",
          "label": "Men's collection (optional)"
        },
        {
          "type": "collection",
          "id": "collection_women",
          "label": "Women's collection (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hats hub",
      "settings": {
        "row_hat_type_heading": "Hat type",
        "row_style_heading": "Style"
      },
      "blocks": [
        {
          "type": "hub_tile",
          "settings": {
