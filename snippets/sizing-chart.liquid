<style>
  .rafter-size-chart-container {
    margin-top: 20px;
    padding: 10px 0;
    font-family: inherit;
  }

  .rafter-size-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 8px;
    border-bottom: 2px solid #000;
    padding-bottom: 4px;
  }

  .rafter-size-title {
    font-family: inherit;
    font-size: 1.4rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: "Playfair Display", "Cormorant SC", serif;
  }

  .rafter-unit-toggle {
    display: flex;
    gap: 15px;
    font-size: 1.2rem;
    font-family: "Playfair Display", "Cormorant SC", serif;
  }

  .rafter-unit-toggle span {
    cursor: pointer;
    color: #888;
    position: relative;
    transition: color 0.2s ease;
  }

  .rafter-unit-toggle span.active {
    color: #4d283b;
    font-weight: bold;
    font-style: italic;
  }

  .rafter-unit-toggle span.active::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #4d283b;
  }

  .rafter-size-table-wrapper {
    overflow-x: auto;
  }

  .rafter-size-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 1.2rem;
    color: #333;
    font-family: "Playfair Display", "Cormorant SC", serif;
  }

  .rafter-size-table th {
    padding: 6px 2px;
    border-bottom: 2px solid #4d283b;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1rem;
    letter-spacing: 0.5px;
    color: #4d283b;
  }

  .rafter-size-table td {
    padding: 4px 2px;
    border-bottom: 1px solid #eee;
  }

  .rafter-size-tip {
    margin-top: 10px;
    font-size: 1.1rem;
    line-height: 1.3;
    color: #444;
    background: #fafafa;
    padding: 8px 12px;
    border-left: 3px solid #1a1a1a;
  }

  .rafter-unit-cm {
    display: none;
  }

  body.rafter-unit-mode-cm .rafter-unit-cm {
    display: table-cell;
  }
  body.rafter-unit-mode-cm .rafter-unit-in {
    display: none;
  }

  [data-unit="cm"] { display: none; }
  .unit-cm [data-unit="cm"] { display: inline; }
  .unit-cm [data-unit="in"] { display: none; }

  .unit-in [data-unit="cm"] { display: none; }
  .unit-in [data-unit="in"] { display: inline; }

</style>

<div class="rafter-size-chart-container unit-in" id="rafterSizeChart">
  <div class="rafter-size-header">
    <h3 class="rafter-size-title">Sizing Guide</h3>
    <div class="rafter-unit-toggle" onclick="toggleRafterUnits()">
      <span id="toggleIn" class="active">Inches</span>
      <span id="toggleCm">Centimeters</span>
    </div>
  </div>

  <div class="rafter-size-table-wrapper">
    <table class="rafter-size-table">
      <thead>
        <tr>
          <th>Hat Size</th>
          <th>Measurement</th>
          <th>General Size</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>6 3/4</td><td><span data-unit="in">21 1/8 Inches</span><span data-unit="cm">54 cm</span></td><td>S</td></tr>
        <tr><td>6 7/8</td><td><span data-unit="in">21 1/2 Inches</span><span data-unit="cm">55 cm</span></td><td>S</td></tr>
        <tr><td>7</td><td><span data-unit="in">21 7/8 Inches</span><span data-unit="cm">56 cm</span></td><td>M</td></tr>
        <tr><td>7 1/8</td><td><span data-unit="in">22 1/4 Inches</span><span data-unit="cm">57 cm</span></td><td>M</td></tr>
        <tr><td>7 1/4</td><td><span data-unit="in">22 5/8 Inches</span><span data-unit="cm">58 cm</span></td><td>L</td></tr>
        <tr><td>7 3/8</td><td><span data-unit="in">23 Inches</span><span data-unit="cm">59 cm</span></td><td>L</td></tr>
        <tr><td>7 1/2</td><td><span data-unit="in">23 1/2 Inches</span><span data-unit="cm">60 cm</span></td><td>XL</td></tr>
        <tr><td>7 5/8</td><td><span data-unit="in">23 7/8 Inches</span><span data-unit="cm">61 cm</span></td><td>XL</td></tr>
        <tr><td>7 3/4</td><td><span data-unit="in">24 1/4 Inches</span><span data-unit="cm">62 cm</span></td><td>XXL</td></tr>
        <tr><td>7 7/8</td><td><span data-unit="in">24 5/8 Inches</span><span data-unit="cm">63 cm</span></td><td>XXL</td></tr>
        <tr><td>8</td><td><span data-unit="in">25 Inches</span><span data-unit="cm">64 cm</span></td><td>XXXL</td></tr>
      </tbody>
    </table>
  </div>

  <div class="rafter-size-tip">
    <strong>Sizing Tip:</strong> If you are in between sizes, go with the larger size! We include free sizing tape with every hat order to help you achieve a perfect custom fit.
  </div>
</div>

<script>
  function toggleRafterUnits() {
    const container = document.getElementById('rafterSizeChart');
    const toggleIn = document.getElementById('toggleIn');
    const toggleCm = document.getElementById('toggleCm');
    
    if (container.classList.contains('unit-in')) {
      container.classList.remove('unit-in');
      container.classList.add('unit-cm');
      toggleIn.classList.remove('active');
      toggleCm.classList.add('active');
    } else {
      container.classList.remove('unit-cm');
      container.classList.add('unit-in');
      toggleCm.classList.remove('active');
      toggleIn.classList.add('active');
    }
  }
</script>
