<style>
  @import url('https://fonts.googleapis.com/css2?family=Tenor+Sans&display=swap');

  .rm-brand-switcher {
    background-color: #f7f7f7;
    border-bottom: 1px solid #e0e0e0;
    display: flex;
    justify-content: flex-start;
    align-items: stretch;
    padding: 0;
    padding-left: 15rem;
    margin: 0;
    position: relative;
  }

  .rm-brand-tabs {
    display: flex;
    align-items: stretch;
    position: relative;
  }

  .rm-brand-tab {
    font-family: 'Tenor Sans', sans-serif;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 24px;
    color: #999;
    text-decoration: none;
    border-right: 1px solid #e0e0e0;
    border-top: 3px solid transparent;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    position: relative;
  }

  .rm-brand-tab.is-active {
    background-color: #ffffff;
    color: #312110;
    border-top: 3px solid #C5A059;
    border-bottom: 1px solid #ffffff;
    margin-bottom: -1px;
    font-weight: 600;
    z-index: 2;
  }

  .rm-brand-tab:hover:not(.is-active) {
    color: #312110;
    background-color: #f0f0f0;
    border-top: 3px solid rgba(197, 160, 89, 0.4);
  }

  /* Slider div kept but hidden — pure CSS handles active state now */
  .rm-tab-slider { display: none; }

  .rm-brand-promo-btn {
    font-family: var(--font-heading-family);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: #312110;
    background-color: transparent;
    border: 1px solid #c5a059;
    padding: 5px 14px;
    margin-left: 24px;
    transition: all 0.3s ease;
    border-radius: 2px;
    align-self: center;
  }

  .rm-brand-promo-btn:hover {
    background-color: #C5A059;
    border-color: #C5A059;
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .rm-brand-switcher { 
      padding-left: 0 !important;
      display: flex !important;
      align-items: stretch !important;
      height: 60px;
    }
    .rm-brand-tabs { 
      flex: 1;
      display: flex !important; 
      align-items: stretch;
    }
    .rm-brand-tab { 
      flex: 1; 
      display: flex;
      align-items: center;
      justify-content: center; 
      font-size: 13px; 
      border-right: 1px solid #e0e0e0;
      border-top: none;
      padding: 0 !important;
    }
    .rm-brand-tab.is-active {
      /* Keep top border as fallback */
    }
    .rm-brand-tab:last-child {
      border-right: none;
    }
    .rm-brand-promo-btn { 
      display: none !important; 
    }
    .rm-brand-hamburger {
      display: flex !important;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 50px;
      background: none;
      border: none;
      border-right: 1px solid #e0e0e0;
      cursor: pointer;
      padding: 0;
    }
    .rm-brand-hamburger svg {
      width: 22px !important;
      height: 22px !important;
    }
    .rm-brand-switcher-cart {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      align-self: stretch;
      flex-shrink: 0;
      width: 50px;
      height: auto !important;
      box-shadow: -1px 0 0 #e0e0e0;
      padding: 0 !important;
      color: #312110 !important;
    }
    .rm-brand-switcher-cart svg {
      width: 22px !important;
      height: 22px !important;
    }
    .rm-brand-switcher-cart .cart-count-bubble {
      position: absolute;
      top: 10px;
      right: 10px;
    }
    /* Hide desktop cart on mobile */
    .header__icon--cart:not(.rm-brand-switcher-cart) {
      display: none !important;
    }
  }
</style>

<div class="rm-brand-switcher">
  <button class="rm-brand-hamburger" onclick="document.querySelector('.header__icon--menu').click();" style="display: none;" aria-label="Menu">
    <svg class="icon icon-hamburger" aria-hidden="true" focusable="false" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1H17" stroke="#312110" stroke-width="2" stroke-linecap="round"/>
      <path d="M1 8H17" stroke="#312110" stroke-width="2" stroke-linecap="round"/>
      <path d="M1 15H17" stroke="#312110" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <div class="rm-brand-tabs" id="rm-brand-tabs">
    {% assign active_index = 0 %}
    {% for block in section.blocks %}
      {% assign tab_link = block.settings.link %}
      {% if tab_link == request.path %}
        {% assign active_index = forloop.index0 %}
      {% elsif tab_link != '/' and request.path contains tab_link %}
        {% assign active_index = forloop.index0 %}
      {% endif %}
    {% endfor %}
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}"
         class="rm-brand-tab {% if forloop.index0 == active_index %}is-active{% endif %}"
         data-tab-index="{{ forloop.index0 }}"
         {{ block.shopify_attributes }}>
        {% if block.settings.title == 'Moon Ridge' %}
          <img src="{{ 'logo-horizontal.png' | asset_url }}" alt="Moon Ridge" style="height: 38px; width: auto; display: block;">
        {% else %}
          {{ block.settings.title }}
        {% endif %}
      </a>
    {% endfor %}
  </div>

  {% if section.settings.promo_button_text != blank %}
    <script id="anywhere_book_now_script" src="https://assets.setmore.com/integration/book-now/live/v1/anywhere-book-now.js"></script>
    <button id="Anywhere_button_iframe" 
            class="rm-brand-promo-btn anywhere-book-now-button" 
            data-booking-url="https://moonridgecompany.setmore.com" 
            data-new-tab="false"
            style="cursor: pointer;">
      {{ section.settings.promo_button_text }}
    </button>
  {% endif %}

  {%- comment -%} Mobile Cart Icon (Rendered directly to prevent jerky loading) {%- endcomment -%}
  <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset rm-brand-switcher-cart" id="cart-icon-bubble-mobile" style="display: none;">
    {%- render 'icon-cart' -%}
    <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
    {%- if cart != empty -%}
      <div class="cart-count-bubble">
        {%- if cart.item_count < 100 -%}
          <span aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
        <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
      </div>
    {%- endif -%}
  </a>
</div>

<script>
  // Show the mobile cart icon on mobile devices
  (function() {
    if (window.innerWidth < 750) {
      var mobileCart = document.getElementById('cart-icon-bubble-mobile');
      if (mobileCart) mobileCart.style.display = 'flex';
    }
  })();
</script>




{% schema %}
{
  "name": "Brand Switcher Tabs",
  "class": "section-brand-switcher",
  "settings": [
    {
      "type": "text",
      "id": "promo_button_text",
      "label": "Promo Button Text",
      "default": "Book A Free Hat Experience"
    },
    {
      "type": "url",
      "id": "promo_button_link",
      "label": "Promo Button Link"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Brand Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Name",
          "default": "Brand Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Tab Link"
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Is Active Tab?",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Switcher Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "title": "Moon Ridge",
            "is_active": true
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "Rafter M",
            "is_active": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
