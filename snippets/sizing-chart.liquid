<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display+SC:wght@400;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

  .rafter-chart-wrap {
    font-family: 'Playfair Display', serif;
    margin: 0;
    padding: 0;
  }

  /* Unit toggle */
  .rafter-chart-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
    font-family: 'Playfair Display SC', serif;
    font-size: 0.85rem;
  }
  .rafter-chart-toggle span {
    cursor: pointer;
    color: #bbb;
    transition: color 0.2s;
    letter-spacing: 0.5px;
  }
  .rafter-chart-toggle span.active {
    color: #4d283b;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .rafter-chart-toggle .sep { color: #ddd; }

  /* Main grid */
  .rafter-chart-grid {
    display: grid;
    grid-template-columns: 1.1fr 1.8fr 1fr;
    border: 2px solid #4d283b;
  }

  /* Header row */
  .rafter-chart-grid .rcg-header {
    background: #4d283b;
    color: #f5e9d0;
    font-family: 'Playfair Display SC', serif;
    font-size: 0.75rem;
    letter-spacing: 1.5px;
    padding: 10px 14px;
    font-weight: 400;
    text-transform: uppercase;
  }

  /* Data cells */
  .rafter-chart-grid .rcg-cell {
    padding: 7px 14px;
    border-bottom: 1px solid #f0e8e0;
    display: flex;
    align-items: center;
  }

  .rafter-chart-grid .rcg-row:last-child .rcg-cell {
    border-bottom: none;
  }

  /* Alternating rows */
  .rafter-chart-grid .rcg-row:nth-child(odd) .rcg-cell {
    background: #fdfaf7;
  }
  .rafter-chart-grid .rcg-row:nth-child(even) .rcg-cell {
    background: #fff;
  }

  /* Hat Size — big and bold */
  .rcg-cell.rcg-hatsize {
    font-family: 'Playfair Display SC', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #2a1318;
    border-right: 2px solid #f0e8e0;
  }

  /* Measurement */
  .rcg-cell.rcg-measurement {
    font-size: 1rem;
    color: #444;
    border-right: 1px solid #f0e8e0;
  }

  /* General size — pill badge */
  .rcg-cell.rcg-general {
    justify-content: center;
  }

  .rcg-size-badge {
    background: #4d283b;
    color: #f5e9d0;
    font-family: 'Playfair Display SC', serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 4px 16px;
    border-radius: 30px;
    letter-spacing: 1px;
    min-width: 44px;
    text-align: center;
  }

  /* Sizing tip */
  .rafter-chart-tip {
    margin-top: 10px;
    padding: 10px 14px;
    background: #fdfaf7;
    border-left: 4px solid #4d283b;
    font-size: 0.9rem;
    color: #333;
    line-height: 1.5;
  }
  .rafter-chart-tip strong {
    font-family: 'Playfair Display SC', serif;
    color: #4d283b;
    font-size: 0.95rem;
  }

  /* Unit show/hide */
  .rafter-chart-wrap.unit-cm [data-unit="in"] { display: none; }
  .rafter-chart-wrap.unit-cm [data-unit="cm"] { display: inline; }
  .rafter-chart-wrap.unit-in [data-unit="cm"] { display: none; }
  .rafter-chart-wrap.unit-in [data-unit="in"] { display: inline; }
</style>

{% assign rows = "6 3/4,21 1/8,54,S|6 7/8,21 1/2,55,S|7,21 7/8,56,M|7 1/8,22 1/4,57,M|7 1/4,22 5/8,58,L|7 3/8,23,59,L|7 1/2,23 1/2,60,XL|7 5/8,23 7/8,61,XL|7 3/4,24 1/4,62,XXL|7 7/8,24 5/8,63,XXL|8,25,64,XXXL" | split: "|" %}

<div class="rafter-chart-wrap unit-in" id="rafterChartWrap">

  <div class="rafter-chart-toggle">
    <span id="rcToggleIn" class="active" onclick="rcToggle('in')">Inches</span>
    <span class="sep">/</span>
    <span id="rcToggleCm" onclick="rcToggle('cm')">Centimeters</span>
  </div>

  <div class="rafter-chart-grid">
    <div class="rcg-header">Hat Size</div>
    <div class="rcg-header">Measurement</div>
    <div class="rcg-header" style="text-align:center;">Size</div>

    {% for row in rows %}
      {% assign cols = row | split: "," %}
      <div class="rcg-row" style="display:contents;">
        <div class="rcg-cell rcg-hatsize">{{ cols[0] }}</div>
        <div class="rcg-cell rcg-measurement">
          <span data-unit="in">{{ cols[1] }} Inches</span>
          <span data-unit="cm">{{ cols[2] }} cm</span>
        </div>
        <div class="rcg-cell rcg-general">
          <span class="rcg-size-badge">{{ cols[3] }}</span>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="rafter-chart-tip">
    <strong>Sizing Tip:</strong> If you are in between sizes, go with the larger size — we include free sizing tape with every hat to help you get the perfect fit.
  </div>

</div>

<script>
  function rcToggle(unit) {
    const wrap = document.getElementById('rafterChartWrap');
    wrap.classList.remove('unit-in', 'unit-cm');
    wrap.classList.add('unit-' + unit);
    document.getElementById('rcToggleIn').classList.toggle('active', unit === 'in');
    document.getElementById('rcToggleCm').classList.toggle('active', unit === 'cm');
  }
</script>
