                              class="progress-bar progress-bar-animated" 
                              role="progressbar" 
                              aria-valuenow="{{ width | replace: '%', '' }}" 
                              aria-valuemin="0" 
                              aria-valuemax="100" 
                              data-width="{{ width }}"
