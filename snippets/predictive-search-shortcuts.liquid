{% comment %}
  Empty-state shortcuts for header predictive search.
  Three style tiles: Western, City, Outdoors/Sportsman (collection handles in header settings).
{% endcomment %}
{%- unless section.settings.search_shortcuts_enabled == false -%}

{%- liquid
  assign western = collections[section.settings.search_shortcut_cowboy_handle]
  assign city = collections[section.settings.search_shortcut_sun_handle]
  assign outdoors = collections[section.settings.search_shortcut_brands_handle]
-%}

<div class="predictive-search-shortcuts" data-predictive-search-shortcuts hidden>
  {%- if section.settings.search_popular_heading != blank -%}
    <p class="predictive-search-shortcuts__heading">{{ section.settings.search_popular_heading | escape }}</p>
  {%- endif -%}

  <ul class="predictive-search-shortcuts__list list-unstyled" role="list">
    {%- if western != blank -%}
      <li>
        <a class="predictive-search-shortcuts__item link" href="{{ western.url }}">
          {%- if western.featured_image != blank -%}
            <img
              src="{{ western.featured_image | image_url: width: 120 }}"
              alt="{{ western.featured_image.alt | default: western.title | escape }}"
              width="48"
              height="48"
              loading="lazy"
              class="predictive-search-shortcuts__image"
            >
          {%- endif -%}
          <span class="predictive-search-shortcuts__label">{{ section.settings.search_shortcut_cowboy_label | default: 'Western' | escape }}</span>
        </a>
      </li>
    {%- endif -%}

    {%- if city != blank -%}
      <li>
        <a class="predictive-search-shortcuts__item link" href="{{ city.url }}">
          {%- if city.featured_image != blank -%}
            <img
              src="{{ city.featured_image | image_url: width: 120 }}"
              alt="{{ city.featured_image.alt | default: city.title | escape }}"
              width="48"
              height="48"
              loading="lazy"
              class="predictive-search-shortcuts__image"
            >
          {%- endif -%}
          <span class="predictive-search-shortcuts__label">{{ section.settings.search_shortcut_sun_label | default: 'City' | escape }}</span>
        </a>
      </li>
    {%- endif -%}

    {%- if outdoors != blank -%}
      <li>
        <a class="predictive-search-shortcuts__item link" href="{{ outdoors.url }}">
          {%- if outdoors.featured_image != blank -%}
            <img
              src="{{ outdoors.featured_image | image_url: width: 120 }}"
              alt="{{ outdoors.featured_image.alt | default: outdoors.title | escape }}"
              width="48"
              height="48"
              loading="lazy"
              class="predictive-search-shortcuts__image"
            >
          {%- endif -%}
          <span class="predictive-search-shortcuts__label">{{ section.settings.search_shortcut_brands_label | default: 'Outdoors/Sportsman' | escape }}</span>
        </a>
      </li>
    {%- endif -%}
  </ul>

  {%- if section.settings.search_popular_queries != blank -%}
    <p class="predictive-search-shortcuts__heading predictive-search-shortcuts__heading--queries">{{ section.settings.search_queries_heading | default: 'Popular searches' | escape }}</p>
    <ul class="predictive-search-shortcuts__queries list-unstyled" role="list">
      {%- assign queries = section.settings.search_popular_queries | newline_to_br | split: '<br />' -%}
      {%- for query_line in queries -%}
        {%- assign query_text = query_line | strip -%}
        {%- if query_text != blank -%}
          <li>
            <a class="predictive-search-shortcuts__query link" href="{{ routes.search_url }}?q={{ query_text | url_param_encode }}">{{ query_text | escape }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

{%- endunless -%}
