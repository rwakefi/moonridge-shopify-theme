{% style %}
  .events-video-banner {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }
  .events-video-banner__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .events-video-banner__bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--video-alignment, center center);
    display: block;
  }
  .events-video-banner__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 2;
  }
  .events-video-banner__content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: #ffffff;
    max-width: 800px;
    padding: 0 20px;
  }
  .events-video-banner__title {
    font-family: var(--font-heading-family);
    font-size: 56px;
    font-weight: 700;
    margin: 0 0 16px 0;
    color: #fff;
    line-height: 1.1;
  }
  .events-video-banner__text {
    font-size: 18px;
    margin: 0 0 32px 0;
    color: #fff;
    line-height: 1.5;
  }
  .events-video-banner__buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .banner-button {
    display: inline-block;
    padding: 14px 32px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .banner-button--primary {
    background: #ffffff;
    color: #111111;
  }
  .banner-button--primary:hover {
    background: #e6e6e6;
  }
  .banner-button--secondary {
    background: transparent;
    color: #ffffff;
    border: 1px solid #ffffff;
  }
  .banner-button--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .events-directory {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
    font-family: var(--font-body-family);
  }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
  }
  .event-category-header {
    grid-column: 1 / -1;
    margin-top: 60px;
    padding-bottom: 24px;
    border-bottom: 1px solid #ddd;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .event-category-header__image-container {
    flex-shrink: 0;
    width: 180px;
    height: 180px;
    border-radius: 8px;
    overflow: hidden;
    border: 6px solid #fff;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }
  .event-category-header__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .event-category-header__text {
    flex-grow: 1;
  }
  .event-category-header h2 {
    font-family: var(--font-heading-family);
    font-size: 36px;
    font-weight: 600;
    color: #111;
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  .event-category-header__desc {
    font-size: 16px;
    color: #555;
    max-width: 700px;
    line-height: 1.6;
  }
  .event-card {
    border: 1px solid #eaeaea;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .event-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }
  .event-card__image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    background: #f5f5f5;
  }
  .event-card__content {
    padding: 24px;
  }
  .event-card__date {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    color: #C5A059;
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }
  .event-card__title {
    font-family: var(--font-heading-family);
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 12px 0;
    color: #111;
  }
  .event-card__desc {
    font-size: 15px;
    color: #555;
    line-height: 1.5;
    margin: 0 0 20px 0;
  }
  .event-card__button {
    display: inline-block;
    padding: 10px 20px;
    background: #111;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.2s;
  }
  .event-card__button:hover {
    background: #333;
  }

  @media screen and (max-width: 768px) {
    .events-video-banner__title {
      font-size: 36px;
    }
    .event-category-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .event-category-header h2 {
      font-size: 26px;
    }
  }
{% endstyle %}

{% if section.settings.hero_video != blank %}
  <div class="events-video-banner" style="--video-alignment: {{ section.settings.video_alignment }};">
    <div class="events-video-banner__bg">
      {{ section.settings.hero_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: "1600x" }}
    </div>
    <div class="events-video-banner__overlay"></div>
      <div class="events-video-banner__content">
      {% if section.settings.banner_title != blank %}
        <h1 class="events-video-banner__title">{{ section.settings.banner_title }}</h1>
      {% endif %}
      {% if section.settings.banner_text != blank %}
        <div class="events-video-banner__text">{{ section.settings.banner_text }}</div>
      {% endif %}
    </div>
  </div>
{% endif %}

<div class="events-directory">
  <div class="events-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category_header' %}
        <div class="event-category-header" id="{{ block.settings.anchor_id | handleize }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="event-category-header__image-container">
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" class="event-category-header__image">
            </div>
          {% endif %}
          <div class="event-category-header__text">
            <h2>{{ block.settings.title }}</h2>
            {% if block.settings.description != blank %}
              <div class="event-category-header__desc">{{ block.settings.description }}</div>
            {% endif %}
          </div>
        </div>
      {% elsif block.type == 'event' %}
        <div class="event-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="event-card__image">
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'event-card__image' }}
          {% endif %}
          
          <div class="event-card__content">
            {% if block.settings.date != blank %}
              <div class="event-card__date">{{ block.settings.date }}</div>
            {% endif %}
            
            <h3 class="event-card__title">{{ block.settings.title }}</h3>
            
            {% if block.settings.description != blank %}
              <div class="event-card__desc">{{ block.settings.description }}</div>
            {% endif %}
            
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="event-card__button">{{ block.settings.button_text }}</a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
    
    {% if section.blocks.size == 0 %}
      <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #777;">
        <p>No events currently scheduled. Add some blocks in the theme editor!</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Events Directory",
  "settings": [
    {
      "type": "video",
      "id": "hero_video",
      "label": "Hero Video (Optional)",
      "info": "Upload a video to Shopify and select it here to display a full-width video at the top."
    },
    {
      "type": "select",
      "id": "video_alignment",
      "label": "Video Focal Point",
      "info": "If the video is cropping, adjust this to focus on the top or bottom.",
      "options": [
        {
          "value": "center top",
          "label": "Top (e.g., show heads)"
        },
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center bottom",
          "label": "Bottom"
        }
      ],
      "default": "center center"
    },
    {
      "type": "text",
      "id": "banner_title",
      "label": "Video Overlay Title",
      "default": "Book Us For Your Next Event"
    },
    {
      "type": "richtext",
      "id": "banner_text",
      "label": "Video Overlay Text",
      "default": "<p>Discover the Moon Ridge experience.</p>"
    }
  ],
  "blocks": [
    {
      "type": "category_header",
      "name": "Category Heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Weddings"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Framed Category Image"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Category Description (Optional)"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor ID",
          "info": "Used for dropdown links. Example: 'weddings'. The link will be /pages/events#weddings",
          "default": "weddings"
        }
      ]
    },
    {
      "type": "event",
      "name": "Event",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Event Image"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date & Time",
          "default": "Oct 15, 2026 | 6:00 PM"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event Title",
          "default": "Hat Shaping Workshop"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Learn the art of custom hat shaping with our expert team.</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "RSVP Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Event Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Events Directory",
      "blocks": [
        {
          "type": "category_header",
          "settings": {
            "title": "Weddings",
            "anchor_id": "weddings"
          }
        },
        {
          "type": "event"
        },
        {
          "type": "category_header",
          "settings": {
            "title": "In Store",
            "anchor_id": "in-store"
          }
        },
        {
          "type": "event"
        }
      ]
    }
  ]
}
{% endschema %}
