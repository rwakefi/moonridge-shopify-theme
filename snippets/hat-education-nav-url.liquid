{% comment %}
  Correct Hat Education submenu URLs when admin menu points both items to one article.
  Sets hat_education_nav_url in parent scope (use include, not render).

  Usage:
  {% include 'hat-education-nav-url', link: childlink %}
{% endcomment %}
{%- liquid
  assign hat_education_nav_url = link.url
  assign link_title_lc = link.title | downcase | strip
  assign link_handle = link.handle | downcase

  if link_handle == 'learn-your-head-shape' or link_title_lc contains 'learn your head'
    assign hat_education_nav_url = '/blogs/hat-education/learn-your-head-shape'
  elsif link_handle == 'hats-and-your-face-shape' or link_handle contains 'finding-the-style' or link_title_lc contains 'face shape'
    assign hat_education_nav_url = '/blogs/hat-education/finding-the-style-that-fits-your-face'
  endif
-%}

