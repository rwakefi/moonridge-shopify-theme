{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title",
          "settings": {
            "title_size": 34
          }
        },
        "sku": {
          "type": "sku",
          "settings": {
            "text_style": "body"
          }
        },
        "price": {
          "type": "price",
          "settings": {
            "price_size": 26,
            "sale_price_color": "#312110",
            "price_bold": true,
            "badge_hide": true,
            "taxes_hide": false,
            "shipping_hide": true
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "settings": {}
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description",
          "settings": {}
        },
        "desc_tab": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Dimensions & Details",
            "icon": "none",
            "content": "<p>Materials, capacity, and dimensions for this item.</p>",
            "page": ""
          }
        },
        "shipping_tab": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "<p>Ships from our store in 1-3 business days. Returns accepted within 30 days in original condition.</p>",
            "page": ""
          }
        },
        "care_tab": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Care Instructions",
            "icon": "washing",
            "content": "<p>Follow care instructions on the product label. Most ceramic drinkware is dishwasher safe unless noted.</p>",
            "page": ""
          }
        },
        "complementary": {
          "type": "complementary",
          "settings": {
            "block_heading": "Pairs well with",
            "make_collapsible_row": true,
            "icon": "none",
            "products_per_page": 4,
            "columns_desktop": 1,
            "color_scheme": "background-1",
            "image_ratio": "square",
            "show_secondary_image": false,
            "show_vendor": false,
            "show_rating": false,
            "enable_quick_add": false
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "sku",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "desc_tab",
        "shipping_tab",
        "care_tab",
        "complementary",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "background-1",
        "media_size": "large",
        "constrain_to_viewport": false,
        "media_fit": "contain",
        "gallery_layout": "thumbnail_slider",
        "media_position": "left",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "show_full_image": true,
        "enable_video_looping": true,
        "padding_top": 40,
        "padding_bottom": 56
      },
      "custom_css": [
        ".product__title h1{letter-spacing:normal;text-transform:none;line-height:1.15;}",
        ".product__accordion .accordion__title{letter-spacing:normal;text-transform:none;}"
      ]
    },
    "featured_drinkware": {
      "type": "featured-collection",
      "settings": {
        "title": "Shop more drinkware",
        "description": "",
        "show_description": false,
        "description_style": "body",
        "collection": "home-goods",
        "products_to_show": 4,
        "columns_desktop": 4,
        "full_width": false,
        "show_view_all": true,
        "view_all_style": "solid",
        "enable_desktop_slider": false,
        "navigation_on_desk": true,
        "color_scheme": "",
        "image_ratio": "square",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "enable_quick_desc": false,
        "quick_desc_legth": 90,
        "quick_desc_size": 14,
        "enable_quick_add": false,
        "show_secondary_add": false,
        "columns_mobile": "2",
        "swipe_on_mobile": true,
        "navigation_on_mobile": true,
        "padding_top": 48,
        "padding_bottom": 20
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "background-1",
        "image_ratio": "square",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "enable_quick_desc": false,
        "quick_desc_legth": 90,
        "quick_desc_size": 14,
        "columns_mobile": "2",
        "padding_top": 20,
        "padding_bottom": 56
      }
    }
  },
  "order": [
    "main",
    "featured_drinkware",
    "related-products"
  ]
}
