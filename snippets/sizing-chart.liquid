<style>
  .rafter-size-chart-container {
    margin-top: 30px;
    padding: 20px;
    background: #fbfbfb;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
  }

  .rafter-size-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
  }

  .rafter-size-title {
    font-family: "Cormorant SC", serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #4d283b;
    margin: 0;
  }

  .rafter-unit-toggle {
    display: flex;
    background: #eee;
    padding: 3px;
    border-radius: 20px;
    cursor: pointer;
  }

  .rafter-unit-toggle span {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .rafter-unit-toggle span.active {
    background: #4d283b;
    color: #fff;
  }

  .rafter-size-table-wrapper {
    overflow-x: auto;
  }

  .rafter-size-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.9rem;
  }

  .rafter-size-table th {
    padding: 12px;
    border-bottom: 2px solid #4d283b;
    color: #4d283b;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .rafter-size-table td {
    padding: 12px;
    border-bottom: 1px solid #eee;
    color: #333;
  }

  .rafter-size-table tr:hover td {
    background: #fdf2f6;
  }

  .rafter-size-tip {
    margin-top: 20px;
    font-size: 0.85rem;
    color: #666;
    font-style: italic;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .rafter-unit-cm {
    display: none;
  }

  body.rafter-unit-mode-cm .rafter-unit-cm {
    display: table-cell;
  }
  body.rafter-unit-mode-cm .rafter-unit-in {
    display: none;
  }

  [data-unit="cm"] { display: none; }
  .unit-cm [data-unit="cm"] { display: inline; }
  .unit-cm [data-unit="in"] { display: none; }

  .unit-in [data-unit="cm"] { display: none; }
  .unit-in [data-unit="in"] { display: inline; }

</style>

<div class="rafter-size-chart-container unit-in" id="rafterSizeChart">
  <div class="rafter-size-header">
    <h3 class="rafter-size-title">OFFICIAL HAT SIZING</h3>
    <div class="rafter-unit-toggle" onclick="toggleRafterUnits()">
      <span id="toggleIn" class="active">IN</span>
      <span id="toggleCm">CM</span>
    </div>
  </div>

  <div class="rafter-size-table-wrapper">
    <table class="rafter-size-table">
      <thead>
        <tr>
          <th>Hat Size</th>
          <th>Measurements</th>
          <th>Letter Size</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>6 3/4</td><td><span data-unit="in">21 1/8"</span><span data-unit="cm">54 cm</span></td><td>S</td></tr>
        <tr><td>6 7/8</td><td><span data-unit="in">21 1/2"</span><span data-unit="cm">55 cm</span></td><td>S</td></tr>
        <tr><td>7</td><td><span data-unit="in">21 7/8"</span><span data-unit="cm">56 cm</span></td><td>M</td></tr>
        <tr><td>7 1/8</td><td><span data-unit="in">22 1/4"</span><span data-unit="cm">57 cm</span></td><td>M</td></tr>
        <tr><td>7 1/4</td><td><span data-unit="in">22 5/8"</span><span data-unit="cm">58 cm</span></td><td>L</td></tr>
        <tr><td>7 3/8</td><td><span data-unit="in">23"</span><span data-unit="cm">59 cm</span></td><td>L</td></tr>
        <tr><td>7 1/2</td><td><span data-unit="in">23 1/2"</span><span data-unit="cm">60 cm</span></td><td>XL</td></tr>
        <tr><td>7 5/8</td><td><span data-unit="in">23 7/8"</span><span data-unit="cm">61 cm</span></td><td>XL</td></tr>
        <tr><td>7 3/4</td><td><span data-unit="in">24 1/4"</span><span data-unit="cm">62 cm</span></td><td>XXL</td></tr>
        <tr><td>7 7/8</td><td><span data-unit="in">24 5/8"</span><span data-unit="cm">63 cm</span></td><td>XXL</td></tr>
        <tr><td>8</td><td><span data-unit="in">25"</span><span data-unit="cm">64 cm</span></td><td>XXXL</td></tr>
      </tbody>
    </table>
  </div>

  <div class="rafter-size-tip">
    <i class="fa-solid fa-circle-info"></i>
    <span>If you are in between sizes, we always recommend going with the <strong>larger size</strong>. We include free sizers with every hat to help you achieve that perfect custom fit.</span>
  </div>
</div>

<script>
  function toggleRafterUnits() {
    const container = document.getElementById('rafterSizeChart');
    const toggleIn = document.getElementById('toggleIn');
    const toggleCm = document.getElementById('toggleCm');
    
    if (container.classList.contains('unit-in')) {
      container.classList.remove('unit-in');
      container.classList.add('unit-cm');
      toggleIn.classList.remove('active');
      toggleCm.classList.add('active');
    } else {
      container.classList.remove('unit-cm');
      container.classList.add('unit-in');
      toggleCm.classList.remove('active');
      toggleIn.classList.add('active');
    }
  }
</script>
