        {
          "type": "hub_tile",
          "settings": {
            "row": "hat_type",
            "title": "Beanies / Flat cap",
            "collection_handle": "beanies-flat-caps"
          }
        },
        {
          "type": "hub_tile",
          "settings": {
            "row": "style",
            "title": "Western",
            "collection_handle": "western-hats",
            "image_metafield_key": "western"
          }
        },
        {
          "type": "hub_tile",
          "settings": {
            "row": "style",
            "title": "City",
            "collection_handle": "city-hats"
          }
        },
        {
          "type": "hub_tile",
          "settings": {
            "row": "style",
            "title": "Outdoors / Sportsman",
            "collection_handle": "outdoors-sportsman-hats"
          }
        }
      ]
    }
  ]
}
{% endschema %}
