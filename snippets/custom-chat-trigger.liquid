<div id="custom-concierge-trigger" class="glass-leather">
  <span>CHAT WITH A HATTER</span>
</div>

<script>
  (function() {
    function initCustomChat() {
      const trigger = document.getElementById('custom-concierge-trigger');
      if (!trigger) return;

      trigger.addEventListener('click', function() {
        // High-end trigger logic for Shopify Inbox
        if (window.ShopifyInbox && typeof window.ShopifyInbox.toggleVisibility === 'function') {
          window.ShopifyInbox.toggleVisibility();
        } 
        else if (window.ShopifyChat && typeof window.ShopifyChat.open === 'function') {
          window.ShopifyChat.open();
        } 
        else {
          // Final fallback: try to find the hidden button iframe specifically and click it
          const buttonIframe = document.querySelector('iframe[name="app-button-iframe"]');
          if (buttonIframe) {
            // Some iframes require clicking inside them, but a JS trigger is safer
            buttonIframe.contentWindow.postMessage('shopify_inbox_toggle_visibility', '*');
            // Try simulated click as well
            buttonIframe.click(); 
          }
        }
      });
    }

    // Wait for everything to be ready
    if (document.readyState === 'complete') {
      initCustomChat();
    } else {
      window.addEventListener('load', initCustomChat);
    }
  })();
</script>

<style>
  /* SURGICAL HIDE - Only target the floating bubble (button), NOT the messenger window */
  iframe[name="app-button-iframe"],
  .shopify-inbox-button { 
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    width: 0 !important;
    height: 0 !important;
    position: absolute !important;
  }

  /* ENSURE the messenger iframe is never hidden by our rules */
  iframe[name="app-messenger-iframe"],
  #shopify-chat-messenger,
  .shopify-inbox-messenger {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
    display: block !important;
  }
  
  #custom-concierge-trigger {
    position: fixed;
    bottom: 30px;
    left: 40px;
    z-index: 9999;
    padding: 14px 24px;
    cursor: pointer;
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.25em;
    color: white;
    transition: transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  }

  #custom-concierge-trigger:hover {
    transform: translateY(-3px) scale(1.02);
    background: var(--rm-leather) !important;
    box-shadow: 0 15px 40px rgba(0,0,0,0.2);
  }

  @media screen and (max-width: 749px) {
    #custom-concierge-trigger {
      bottom: 20px;
      left: 20px;
      padding: 12px 18px;
      font-size: 9px;
    }
  }
</style>
