{% doc %}
  @prompt
    A PAge Display like the others except exclude the title
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-page-display-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-page-display-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-page-display-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
  }

  .ai-page-display-content-{{ ai_gen_id }} p {
    margin-bottom: 1em;
  }

  .ai-page-display-content-{{ ai_gen_id }} h1,
  .ai-page-display-content-{{ ai_gen_id }} h2,
  .ai-page-display-content-{{ ai_gen_id }} h3,
  .ai-page-display-content-{{ ai_gen_id }} h4,
  .ai-page-display-content-{{ ai_gen_id }} h5,
  .ai-page-display-content-{{ ai_gen_id }} h6 {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .ai-page-display-content-{{ ai_gen_id }} ul,
  .ai-page-display-content-{{ ai_gen_id }} ol {
    margin-bottom: 1em;
    padding-left: 2em;
  }

  .ai-page-display-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-page-display-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-page-display-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-page-display-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-page-display-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-page-display-container-{{ ai_gen_id }}">
    {% if block.settings.page != blank %}
      <div class="ai-page-display-content-{{ ai_gen_id }}">
        {{ block.settings.page.content }}
      </div>
    {% else %}
      <div class="ai-page-display-content-{{ ai_gen_id }}" style="text-align: center; color: #999; padding: 40px 20px;">
        <p>Select a page to display its content</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Page display",
  "settings": [
    {
      "type": "page",
      "id": "page",
      "label": "Page"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size (mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.6
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1f1d24"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link",
      "default": "#312110"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal (mobile)",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Page display"
    }
  ]
}
{% endschema %}