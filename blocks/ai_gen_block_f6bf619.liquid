{% doc %}
  @prompt
    a section the same size as the lumen slideshow section below, this will just be a single picture, it needs to be 1920 by 1080, add a mobile image that is 1080 by 1350
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- liquid
  assign desktop_img = block.settings.desktop_image
  assign mobile_img = block.settings.mobile_image
  if mobile_img == blank
    assign mobile_img = desktop_img
  endif

  assign desktop_w = desktop_img.width | default: 1920
  assign desktop_h = desktop_img.height | default: 1080
  assign mobile_w = mobile_img.width | default: 1080
  assign mobile_h = mobile_img.height | default: 1350

  assign desktop_widths = '750,1100,1500,1780,1920' | split: ','
  assign mobile_widths = '400,550,750,900,1080' | split: ','
-%}

{%- capture desktop_srcset -%}
  {%- for w in desktop_widths -%}
    {%- assign wn = w | plus: 0 -%}
    {%- if desktop_w >= wn -%}{{ desktop_img | image_url: width: wn }} {{ wn }}w, {% endif -%}
  {%- endfor -%}
  {{ desktop_img | image_url }} {{ desktop_w }}w
{%- endcapture -%}

{%- capture mobile_srcset -%}
  {%- for w in mobile_widths -%}
    {%- assign wn = w | plus: 0 -%}
    {%- if mobile_w >= wn -%}{{ mobile_img | image_url: width: wn }} {{ wn }}w, {% endif -%}
  {%- endfor -%}
  {{ mobile_img | image_url }} {{ mobile_w }}w
{%- endcapture -%}

{% style %}
  .ai-single-image-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-single-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
  }

  .ai-single-image-media-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ desktop_w }} / {{ desktop_h }};
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-single-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-single-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-single-image-media-{{ ai_gen_id }} {
      aspect-ratio: {{ mobile_w }} / {{ mobile_h }};
    }

    .ai-single-image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: 1080 / 1350;
    }
  }
{% endstyle %}

<div class="ai-single-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-single-image-wrapper-{{ ai_gen_id }}">
    {% if desktop_img %}
      <picture>
        <source
          media="(max-width: 749px)"
          srcset="{{ mobile_srcset | strip | strip_newlines }}"
          sizes="100vw"
          width="{{ mobile_w }}"
          height="{{ mobile_h }}"
        >
        <img
          src="{{ desktop_img | image_url: width: 1920 }}"
          srcset="{{ desktop_srcset | strip | strip_newlines }}"
          sizes="100vw"

          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="{{ desktop_w }}"
          height="{{ desktop_h }}"
          class="ai-single-image-media-{{ ai_gen_id }}"
        >
      </picture>
    {% else %}
      <div class="ai-single-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-single-image-empty-state-{{ ai_gen_id }}">
          Add a desktop image (1920 x 1080)
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Single image",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended size: 1920 x 1080 pixels"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended size: 1080 x 1350 pixels. If not set, desktop image will be used."
    }
  ],
  "presets": [
    {
      "name": "Single image"
    }
  ],
  "tag": null
}
{% endschema %}
