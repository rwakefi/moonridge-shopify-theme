{% doc %}
  @prompt
    AI generated
    
    
    a best sells collection carousel that will work well with mobile, make the font less bold, make the navigation little arrows on the side, make this were four products fit in the viewable area on mobile 2 on top and 2 on bottom, add the ability to srole or arrow to more products, add the sales and sale brice badge, make the sale price the word sale instead of a percentage, show four products stacked, go back to the last version
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bestsellers-carousel-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-bestsellers-carousel__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-bestsellers-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 30px;
  }

  .ai-bestsellers-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 400;
  }

  .ai-bestsellers-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-bestsellers-carousel__track-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.collection.products.size | default: 12 }}, calc((100% - ({{ block.settings.products_per_row | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.products_per_row }}));
    gap: {{ block.settings.grid_gap }}px;
    transition: transform 0.4s ease;
    touch-action: pan-y;
  }

  .ai-bestsellers-carousel__product-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .ai-bestsellers-carousel__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 12px;
  }

  .ai-bestsellers-carousel__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bestsellers-carousel__image-wrapper-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bestsellers-carousel__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_offset }}px;
    right: {{ block.settings.badge_offset }}px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    z-index: 1;
  }

  .ai-bestsellers-carousel__info-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-bestsellers-carousel__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    margin: 0 0 8px;
    font-weight: 400;
    color: {{ block.settings.text_color }};
  }

  .ai-bestsellers-carousel__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-bestsellers-carousel__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 400;
  }

  .ai-bestsellers-carousel__price--sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-bestsellers-carousel__price--compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    font-size: {{ block.settings.price_size | times: 0.9 }}px;
  }

  .ai-bestsellers-carousel__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_background }};
    border: 1px solid {{ block.settings.nav_border_color }};
    border-radius: 50%;
    width: {{ block.settings.nav_size }}px;
    height: {{ block.settings.nav_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: all 0.3s ease;
  }

  .ai-bestsellers-carousel__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_background }};
  }

  .ai-bestsellers-carousel__nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-bestsellers-carousel__nav--prev-{{ ai_gen_id }} {
    left: -{{ block.settings.nav_offset }}px;
  }

  .ai-bestsellers-carousel__nav--next-{{ ai_gen_id }} {
    right: -{{ block.settings.nav_offset }}px;
  }

  .ai-bestsellers-carousel__nav-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    stroke: {{ block.settings.nav_icon_color }};
  }

  .ai-bestsellers-carousel__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
  }

  @media screen and (max-width: 749px) {
    .ai-bestsellers-carousel__track-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.collection.products.size | default: 12 }}, calc(50% - {{ block.settings.grid_gap | divided_by: 2 }}px));
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-bestsellers-carousel__track-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-bestsellers-carousel__product-{{ ai_gen_id }} {
      scroll-snap-align: start;
    }

    .ai-bestsellers-carousel__nav--prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-bestsellers-carousel__nav--next-{{ ai_gen_id }} {
      right: 10px;
    }

    .ai-bestsellers-carousel__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<bestsellers-carousel-{{ ai_gen_id }} class="ai-bestsellers-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bestsellers-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-bestsellers-carousel__header-{{ ai_gen_id }}">
        <h2 class="ai-bestsellers-carousel__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    {% if block.settings.collection != blank and block.settings.collection.products.size > 0 %}
      <div class="ai-bestsellers-carousel__wrapper-{{ ai_gen_id }}">
        <button
          class="ai-bestsellers-carousel__nav-{{ ai_gen_id }} ai-bestsellers-carousel__nav--prev-{{ ai_gen_id }}"
          aria-label="Previous products"
          data-nav="prev"
        >
          <svg class="ai-bestsellers-carousel__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="ai-bestsellers-carousel__track-{{ ai_gen_id }}" data-track>
          {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
            <a href="{{ product.url }}" class="ai-bestsellers-carousel__product-{{ ai_gen_id }}">
              <div class="ai-bestsellers-carousel__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-bestsellers-carousel__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag }}
                {% endif %}

                {% if product.compare_at_price > product.price %}
                  <div class="ai-bestsellers-carousel__badge-{{ ai_gen_id }}">
                    {{ block.settings.badge_text }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-bestsellers-carousel__info-{{ ai_gen_id }}">
                <h3 class="ai-bestsellers-carousel__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                <div class="ai-bestsellers-carousel__price-wrapper-{{ ai_gen_id }}">
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-bestsellers-carousel__price-{{ ai_gen_id }} ai-bestsellers-carousel__price--sale-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>
                    <span class="ai-bestsellers-carousel__price-{{ ai_gen_id }} ai-bestsellers-carousel__price--compare-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% else %}
                    <span class="ai-bestsellers-carousel__price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>
                  {% endif %}
                </div>
              </div>
            </a>
          {% endfor %}
        </div>

        <button
          class="ai-bestsellers-carousel__nav-{{ ai_gen_id }} ai-bestsellers-carousel__nav--next-{{ ai_gen_id }}"
          aria-label="Next products"
          data-nav="next"
        >
          <svg class="ai-bestsellers-carousel__nav-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% else %}
      <div class="ai-bestsellers-carousel__empty-{{ ai_gen_id }}">
        <p>Select a collection to display best sellers</p>
      </div>
    {% endif %}
  </div>
</bestsellers-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class BestsellersCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.itemsPerSlide = 4;
        this.isMobile = window.innerWidth <= 749;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.prevBtn = this.querySelector('[data-nav="prev"]');
        this.nextBtn = this.querySelector('[data-nav="next"]');
        
        if (!this.track) return;

        this.products = Array.from(this.track.children);
        this.totalProducts = this.products.length;

        this.prevBtn.addEventListener('click', () => this.navigate(-1));
        this.nextBtn.addEventListener('click', () => this.navigate(1));

        if (this.isMobile) {
          this.track.addEventListener('scroll', () => this.handleScroll());
        }

        window.addEventListener('resize', () => this.handleResize());

        this.updateNavigation();
      }

      navigate(direction) {
        if (this.isMobile) {
          const scrollAmount = this.track.offsetWidth * direction;
          this.track.scrollBy({
            left: scrollAmount,
            behavior: 'smooth'
          });
        } else {
          this.currentIndex += direction;
          
          const maxIndex = Math.max(0, this.totalProducts - this.itemsPerSlide);
          
          if (this.currentIndex < 0) {
            this.currentIndex = 0;
          } else if (this.currentIndex > maxIndex) {
            this.currentIndex = maxIndex;
          }

          this.updateDesktopPosition();
        }
        
        this.updateNavigation();
      }

      updateDesktopPosition() {
        if (this.isMobile) return;
        
        const productWidth = this.products[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const offset = -(this.currentIndex * (productWidth + gap));
        
        this.track.style.transform = `translateX(${offset}px)`;
      }

      handleScroll() {
        if (!this.isMobile) return;
        
        clearTimeout(this.scrollTimeout);
        this.scrollTimeout = setTimeout(() => {
          this.updateNavigation();
        }, 100);
      }

      handleResize() {
        const wasMobile = this.isMobile;
        this.isMobile = window.innerWidth <= 749;
        
        if (wasMobile !== this.isMobile) {
          this.currentIndex = 0;
          this.track.style.transform = '';
          this.track.scrollLeft = 0;
          this.updateNavigation();
        }
      }

      updateNavigation() {
        if (this.isMobile) {
          const isAtStart = this.track.scrollLeft <= 0;
          const isAtEnd = this.track.scrollLeft >= this.track.scrollWidth - this.track.offsetWidth - 10;
          
          this.prevBtn.disabled = isAtStart;
          this.nextBtn.disabled = isAtEnd;
        } else {
          const maxIndex = Math.max(0, this.totalProducts - this.itemsPerSlide);
          
          this.prevBtn.disabled = this.currentIndex === 0;
          this.nextBtn.disabled = this.currentIndex >= maxIndex;
        }
      }
    }

    customElements.define('bestsellers-carousel-{{ ai_gen_id }}', BestsellersCarousel{{ ai_gen_id }});
  })();
</script>

