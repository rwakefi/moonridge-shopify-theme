                    {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- endif -%}
                  {%- endunless -%}
                </div>
              <div {{ block.shopify_attributes }}>
                {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                {%- endform -%}
              </div>
                 {%- when 'inventory_status' -%}

              {% liquid
                  assign low_stock_count      = block.settings.inventory_threshold
              
                  assign text_stock_normal    = 'Currently, <b>[count] items</b> are in stock!'
                  assign color_stock_normal   = block.settings.normal_color
                  assign width_stock_normal   = '70%'

                  assign text_stock_always    = 'In stock!'
                  assign color_stock_always   = block.settings.normal_color
                  assign width_stock_always   = '100%'
              
                  assign text_stock_low       = 'Only, <b>[count] items</b> are left in stock!'
                  assign color_stock_low      = block.settings.low_color
                  assign width_stock_low      = '10%'
              
                  assign text_stock_none      = 'Unfortunately, this item is sold-out!'
                  assign color_stock_none     = '#D32F2F'
                  assign width_stock_none     = '0%'
              %}
              
              
              {% liquid
                  assign current_variant = product.selected_or_first_available_variant
              
                  if current_variant.inventory_quantity <= 0
                      assign text = text_stock_none
                      assign color = color_stock_none
                      assign width = width_stock_none
                  elsif block.settings.inventory_threshold  == 0
                      assign text = text_stock_always
                      assign color = color_stock_always
                      assign width = width_stock_always
                  elsif current_variant.inventory_quantity <= low_stock_count
                      assign text = text_stock_low | replace: '[count]', current_variant.inventory_quantity
                      assign color = color_stock_low
                      assign width = width_stock_low
                  else
                      assign text = text_stock_normal | replace: '[count]', current_variant.inventory_quantity
                      assign color = color_stock_normal
                      assign width = width_stock_normal
                  endif
              %}
              
              <style>
              
              .progress {
                  display: flex;
                  height: 0.4rem;
                  overflow: hidden;
                  font-size: 0.75rem;
                  background-color: {{block.settings.background_bar}};
                  border-radius: 0rem;
              }
              
              .progress-bar {
                  display: flex !important;
                  flex-direction: column;
                  justify-content: center;
                  overflow: hidden;
                  height: 0.4rem;
                  color: #fff;
                  text-align: center;
                  white-space: nowrap;
                  background-color: #0d6efd;
                  transition: width 0.6s ease;
              }
              
              @media (prefers-reduced-motion: reduce) {
                  .progress-bar { transition: none; }
              }
              
              
              /*
                  Snippet styles
              */
              #lumin-stock-indicator-bar {
                  margin-bottom: 1.75rem;
              }
              {% if block.settings.text_style == 'subtitle' %}
              #lumin-stock-indicator-bar-text {
                  margin: 0 0 0.8rem;
                  letter-spacing: .25rem;
                  font-size: 1.3rem;
              }
              {% elsif block.settings.text_style == 'uppercase'%}
                 #lumin-stock-indicator-bar-text {
                  margin: 0 0 0.8rem;
                  text-transform: uppercase;
                  letter-spacing: .25rem;
                  font-size: 1.3rem;
              }
                {% else %}
                 #lumin-stock-indicator-bar-text {
                  margin: 0 0 0.8rem;
              }
                {% endif %}
              </style>
              
              <script>
              window.addEventListener('DOMContentLoaded', () => {
                  const luminStockIndicatorBar = document.querySelector('#lumin-stock-indicator-bar')
                  
                  luminStockIndicatorBar.style.display = 'block'
              
                  const initWidth = () => {
                      setTimeout(() => {
                          const progressBar = document.querySelector('#lumin-stock-indicator-bar .progress-bar')
                          progressBar.style.width = progressBar.dataset.width
                      }, 500)
                  }
                  initWidth()
              
                  document.querySelector('[name="id"]').addEventListener('change', async () => {
                      document.querySelector('#lumin-stock-indicator-bar-inner').style.opacity = '.25'
              
                      const respoonse = await fetch(window.location.href)
                      const data = await respoonse.text()
              
                      const parser = new DOMParser()
                      const newDocument = parser.parseFromString(data, 'text/html')
              
                      document.querySelector('#lumin-stock-indicator-bar-inner')
                          .replaceWith(newDocument.querySelector('#lumin-stock-indicator-bar-inner'))
              
                      initWidth()
                  })
              })
              </script>
              
              <div id="lumin-stock-indicator-bar" style="display: block;" {{ block.shopify_attributes }}>
                  <div id="lumin-stock-indicator-bar-inner">
                      <p id="lumin-stock-indicator-bar-text">
                          {{ text }}
                      </p>
                    {% if block.settings.show_inventory_bar %}
                      <div class="progress">
