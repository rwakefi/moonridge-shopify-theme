                                         <progress-bar class="{{ block.settings.color_scheme }} progress-bar" data-quantity="{{ product.selected_or_first_available_variant.inventory_quantity }}"></progress-bar>
              
                      <svg class="icon icon-check" width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13.0523 20L8.33301 15.2807L9.27891 14.3348L13.0523 18.1082L21.1605 10L22.1064 10.9459L13.0523 20Z" fill="currentColor"></path>
                      </svg>
                      {%- if block.settings.show_inventory_quantity -%}
                        {{- 'products.product.inventory_low_stock_show_count' | t: quantity: product.selected_or_first_available_variant.inventory_quantity -}}
                        {%- else -%}
