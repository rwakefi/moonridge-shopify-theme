{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }},
  .home-hub-{{ section.id }} {
    --home-hub-accent: {{ section.settings.accent_color }};
    --home-hub-ink: #312110;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  .home-hub-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .home-hub-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-hub-{{ section.id }} .home-hub__inner {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .home-hub-{{ section.id }} .home-hub__crumbs {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--home-hub-ink);
  }

  .home-hub-{{ section.id }} .home-hub__crumbs li {
    display: inline-flex;
    align-items: center;
  }

  .home-hub-{{ section.id }} .home-hub__crumbs li:not(:last-child)::after {
    content: '/';
    margin: 0 1.2rem;
    color: rgba(49, 33, 16, 0.35);
    font-weight: 300;
  }

  .home-hub-{{ section.id }} .home-hub__crumbs a {
    color: var(--home-hub-ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .home-hub-{{ section.id }} .home-hub__crumbs a:hover {
    color: var(--home-hub-accent);
  }

  .home-hub-{{ section.id }} .home-hub__crumbs [aria-current="page"] {
    color: rgba(49, 33, 16, 0.55);
  }

  .home-hub-{{ section.id }} .home-hub__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .home-hub-{{ section.id }} .home-hub__title {
    margin: 0 0 0.75rem;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--home-hub-ink);
    font-weight: 500;
  }

  .home-hub-{{ section.id }} .home-hub__intro {
    margin: 0 auto;
    max-width: 42rem;
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(49, 33, 16, 0.8);
  }

  .home-hub-{{ section.id }} .home-hub__row-title {
    margin: 0 0 1.6rem;
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--home-hub-ink);
    font-weight: 500;
    font-family: var(--font-heading-family);
  }

  .home-hub-{{ section.id }} .home-hub__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .home-hub-{{ section.id }} .home-hub__grid {
      gap: 1.6rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .home-hub-{{ section.id }} .home-hub__grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }

  .home-hub-{{ section.id }} .home-hub__tile {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(49, 33, 16, 0.1);
    background: transparent;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .home-hub-{{ section.id }} .home-hub__tile:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(49, 33, 16, 0.12);
    border-color: var(--home-hub-accent);
  }

  .home-hub-{{ section.id }} .home-hub__tile-media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: transparent;
  }

  .home-hub-{{ section.id }} .home-hub__tile-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .home-hub-{{ section.id }} .home-hub__tile:hover .home-hub__tile-media img {
    transform: scale(1.04);
  }

  .home-hub-{{ section.id }} .home-hub__tile-label {
    padding: 1.2rem 1rem;
    text-align: center;
    font-family: var(--font-heading-family);
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--home-hub-ink);
  }

  .home-hub-{{ section.id }} .home-hub__footer-link {
    display: block;
    text-align: center;
    margin-top: 3rem;
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--home-hub-accent);
    text-decoration: none;
    font-family: var(--font-heading-family);
  }

  .home-hub-{{ section.id }} .home-hub__footer-link:hover {
    text-decoration: underline;
  }
{%- endstyle -%}

<section class="home-hub-{{ section.id }}" id="home-hub-{{ section.id }}">
  <div class="home-hub__inner page-width">
    <nav aria-label="Breadcrumb">
      <ol class="home-hub__crumbs">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li><span aria-current="page">{{ section.settings.breadcrumb_label | default: 'Home goods' | escape }}</span></li>
      </ol>
    </nav>

    <header class="home-hub__header">
      {%- if section.settings.heading != blank -%}
        <h1 class="home-hub__title">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="home-hub__intro">{{ section.settings.intro | escape }}</p>
      {%- endif -%}
    </header>

    {%- assign from_param = '?from=home-hub' -%}

    {%- if section.settings.row_heading != blank -%}
      <h2 class="home-hub__row-title">{{ section.settings.row_heading | escape }}</h2>
    {%- endif -%}

    <ul class="home-hub__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'hub_tile' -%}
          {%- liquid
            assign tile_collection = block.settings.collection
            if tile_collection == blank and block.settings.collection_handle != blank
              assign tile_collection = collections[block.settings.collection_handle]
            endif
          -%}
          <li {{ block.shopify_attributes }}>
            <a
              class="home-hub__tile"
              href="{% if tile_collection %}{{ tile_collection.url }}{{ from_param }}{% else %}#{% endif %}"
            >
              <div class="home-hub__tile-media">
                {%- render 'hats-hub-tile-media',
                  block_image: block.settings.image,
                  image_metafield_key: '',
                  collection_all: tile_collection,
                  collection_men: blank,
                  collection_women: blank,
                  metafield_search_collection: section.settings.image_fallback_collection,
                  title: block.settings.title
                -%}
              </div>
              <span class="home-hub__tile-label">{{ block.settings.title | escape }}</span>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- assign shop_all = section.settings.shop_all_collection -%}
    {%- if shop_all != blank -%}
      <a class="home-hub__footer-link" href="{{ shop_all.url }}{{ from_param }}">
        {{ section.settings.shop_all_label | default: 'Shop all home goods' | escape }} →
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Home hub",
  "tag": "section",
  "class": "section-home-hub",
  "settings": [
    {
      "type": "text",
      "id": "breadcrumb_label",
      "label": "Breadcrumb label",
      "default": "Home goods"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop home"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction",
      "default": "Blankets, bath, mugs, and more — curated for the home."
    },
    {
      "type": "text",
      "id": "row_heading",
      "label": "Category row heading",
      "default": "Shop by category"
    },
    {
      "type": "collection",
      "id": "image_fallback_collection",
      "label": "Fallback collection for tile images",
      "info": "When a tile has no image, the first product image from this collection may be used."
    },
    {
      "type": "collection",
      "id": "shop_all_collection",
      "label": "Shop all collection"
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "Shop all link label",
      "default": "Shop all home goods"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#C5A059"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "hub_tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Bath"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle",
          "info": "e.g. bath, mugs, blankets. Used when no collection is picked below."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)",
          "info": "1200×1200 recommended. Overrides collection image."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home hub",
      "blocks": [
        {
          "type": "hub_tile",
          "settings": {
            "title": "Bath",
            "collection_handle": "bath"
          }
        },
        {
          "type": "hub_tile",
          "settings": {
            "title": "Blankets",
            "collection_handle": "blankets"
          }
        },
        {
          "type": "hub_tile",
          "settings": {
            "title": "Mugs",
            "collection_handle": "mugs"
          }
        },
        {
          "type": "hub_tile",
          "settings": {
            "title": "Robes",
            "collection_handle": "robes"
          }
        },
        {
          "type": "hub_tile",
          "settings": {
            "title": "Candles",
            "collection_handle": "candles"
          }
        }
      ]
    }
  ]
}
{% endschema %}
